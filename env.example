# ========================
# REQUIRED VARIABLES
# ========================

# Server Port (Render will provide this)
PORT=3000

# MongoDB Atlas Connection String
# Get this from MongoDB Atlas: Database → Connect → Drivers
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smart-edu?retryWrites=true&w=majority

# Session Secret (generate a random string - at least 32 characters)
# Use: openssl rand -base64 32
SESSION_SECRET=your-super-secret-session-key-min-32-chars

# ========================
# NODE ENVIRONMENT
# ========================
NODE_ENV=production

# ========================
# EMAIL CONFIGURATION (REQUIRED for OTP)
# ========================

# Gmail with App Password (recommended)
# 1. Enable 2-Step Verification in Google Account
# 2. Go to App Passwords in security settings
# 3. Create new app password for "Mail"
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password

# Alternative: SMTP Configuration
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587

# ========================
# OPTIONAL: TWILIO (SMS)
# ========================

# Only required if you want real SMS
# Get free trial: https://www.twilio.com/
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# ========================
# OPTIONAL: PUSH NOTIFICATIONS
# ========================

# Generate keys: https://vapidkeys.com/
# VAPID_PUBLIC_KEY=your_vapid_public_key
# VAPID_PRIVATE_KEY=your_vapid_private_key

# ========================
# OPTIONAL: AI CHATBOT
# ========================

# Google Gemini (free tier available)
# Get key: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_api_key

# OR Groq (free tier available)
# Get key: https://console.groq.com/
# GROQ_API_KEY=your_groq_api_key

# ========================
# CORS CONFIGURATION
# ========================

# Your Render domain after deployment
# Format: https://your-app-name.onrender.com
ALLOWED_ORIGINS=https://your-app-name.onrender.com
