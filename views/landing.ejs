<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/landing-page.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
</head>
<body>
    <!-- Background Effects -->
    <div class="background-effects">
        <div class="fullscreen-glass"></div>
        <div class="gradient-mesh"></div>
        <div class="particles" id="particles"></div>
        <div class="cursor-glow" id="cursor-glow"></div>
        <div class="noise-overlay"></div>
        <div class="vignette"></div>
        <!-- SVG Morphing Shapes -->
        <svg class="morphing-shapes" viewBox="0 0 1000 1000" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <linearGradient id="morphGradient1" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3" />
                    <stop offset="100%" style="stop-color:#8b5cf6;stop-opacity:0.1" />
                </linearGradient>
                <linearGradient id="morphGradient2" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" style="stop-color:#10b981;stop-opacity:0.2" />
                    <stop offset="100%" style="stop-color:#f59e0b;stop-opacity:0.1" />
                </linearGradient>
            </defs>
            <path id="morphPath1" fill="url(#morphGradient1)" d="M200,300 Q400,200 600,300 T1000,300 V1000 H0 Z" />
            <path id="morphPath2" fill="url(#morphGradient2)" d="M800,700 Q600,600 400,700 T0,700 V1000 H1000 Z" />
        </svg>
    </div>

    <!-- Glass Navbar -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-brand">
                <i class="fas fa-graduation-cap"></i>
                <span>SmartEdu</span>
            </div>
            <div class="nav-links">
                <a href="#premium-features" class="nav-link">Premium</a>
                <a href="#features" class="nav-link">Features</a>
                <a href="#showcase" class="nav-link">Showcase</a>
                <a href="#testimonials" class="nav-link">Testimonials</a>
                <a href="/login" class="btn btn-ghost">Login</a>
                <a href="/register" class="btn btn-primary btn-magnetic">Register</a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h1 class="hero-title">
                <span class="title-main">SmartEdu</span>
                <span class="title-accent">Revolutionize</span>
                <span class="title-sub">Learning</span>
            </h1>
            <p class="hero-subtitle">
                Experience the future of education with our cinematic dark mode learning platform.
                Immerse yourself in premium knowledge delivery.
            </p>
            <div class="hero-ctas">
                <a href="/register" class="btn btn-primary btn-large btn-magnetic">Get Started</a>
                <a href="#premium-features" class="btn btn-secondary btn-large">Explore Premium</a>
            </div>
        </div>
        <div class="hero-visual">
            <div class="floating-mockup">
                <div class="mockup-screen"></div>
                <div class="ambient-glow"></div>
            </div>
        </div>
    </section>

    <!-- Premium Learning Features Section -->
    <section id="premium-features" class="premium-features">
        <div class="container">
            <div class="premium-header">
                <h2 class="section-title">Premium Learning Features</h2>
                <p class="section-subtitle">Unlock the full potential of cinematic education with our exclusive premium features designed for serious learners.</p>
                <div class="premium-stats">
                    <div class="premium-stat">
                        <span class="stat-number">500+</span>
                        <span class="stat-label">Premium Users</span>
                    </div>
                    <div class="premium-stat">
                        <span class="stat-number">98%</span>
                        <span class="stat-label">Satisfaction Rate</span>
                    </div>
                    <div class="premium-stat">
                        <span class="stat-number">24/7</span>
                        <span class="stat-label">Premium Support</span>
                    </div>
                </div>
            </div>
            <div class="premium-features-grid">
                <div class="premium-feature-card glass-card premium-card" data-feature="ai">
                    <div class="premium-card-header">
                        <div class="premium-icon">🎯</div>
                        <div class="premium-badge">Premium</div>
                    </div>
                    <h3>AI-Powered Learning Paths</h3>
                    <p>Personalized learning journeys adapted to your pace and goals using advanced AI algorithms.</p>
                    <div class="premium-feature-highlight">
                        <span>Adaptive Difficulty</span>
                        <span>Progress Tracking</span>
                        <span>Smart Recommendations</span>
                    </div>
                    <div class="card-glow"></div>
                </div>
                <div class="premium-feature-card glass-card premium-card" data-feature="video">
                    <div class="premium-card-header">
                        <div class="premium-icon">🎥</div>
                        <div class="premium-badge">Premium</div>
                    </div>
                    <h3>4K Video Lectures</h3>
                    <p>Crystal-clear, high-definition video content with interactive overlays and real-time note synchronization.</p>
                    <div class="premium-feature-highlight">
                        <span>HD Quality</span>
                        <span>Interactive Controls</span>
                        <span>Offline Access</span>
                    </div>
                    <div class="card-glow"></div>
                </div>
                <div class="premium-feature-card glass-card premium-card" data-feature="analytics">
                    <div class="premium-card-header">
                        <div class="premium-icon">📊</div>
                        <div class="premium-badge">Premium</div>
                    </div>
                    <h3>Advanced Analytics</h3>
                    <p>Deep insights into your learning patterns with predictive performance forecasting and detailed progress reports.</p>
                    <div class="premium-feature-highlight">
                        <span>Performance Insights</span>
                        <span>Predictive Analytics</span>
                        <span>Custom Reports</span>
                    </div>
                    <div class="card-glow"></div>
                </div>
                <div class="premium-feature-card glass-card premium-card" data-feature="neural">
                    <div class="premium-card-header">
                        <div class="premium-icon">🧠</div>
                        <div class="premium-badge">Premium</div>
                    </div>
                    <h3>Neural Study Sessions</h3>
                    <p>Brain-optimized study techniques with spaced repetition and memory enhancement algorithms.</p>
                    <div class="premium-feature-highlight">
                        <span>Spaced Repetition</span>
                        <span>Memory Boost</span>
                        <span>Focus Modes</span>
                    </div>
                    <div class="card-glow"></div>
                </div>
                <div class="premium-feature-card glass-card premium-card" data-feature="collaboration">
                    <div class="premium-card-header">
                        <div class="premium-icon">🤝</div>
                        <div class="premium-badge">Premium</div>
                    </div>
                    <h3>Collaborative Learning</h3>
                    <p>Connect with peers and mentors in exclusive study groups with real-time collaboration tools.</p>
                    <div class="premium-feature-highlight">
                        <span>Study Groups</span>
                        <span>Mentor Access</span>
                        <span>Live Sessions</span>
                    </div>
                    <div class="card-glow"></div>
                </div>
                <div class="premium-feature-card glass-card premium-card" data-feature="certification">
                    <div class="premium-card-header">
                        <div class="premium-icon">🏆</div>
                        <div class="premium-badge">Premium</div>
                    </div>
                    <h3>Premium Certification</h3>
                    <p>Earn industry-recognized certificates with blockchain verification and lifetime validity.</p>
                    <div class="premium-feature-highlight">
                        <span>Blockchain Verified</span>
                        <span>Lifetime Valid</span>
                        <span>Industry Recognition</span>
                    </div>
                    <div class="card-glow"></div>
                </div>
            </div>
            <div class="premium-showcase">
                <div class="premium-demo">
                    <div class="demo-screen glass-card">
                        <div class="demo-content">
                            <div class="demo-header">
                                <div class="demo-avatar">👤</div>
                                <div class="demo-info">
                                    <div class="demo-name">Premium Dashboard</div>
                                    <div class="demo-status">Active Learning Session</div>
                                </div>
                            </div>
                            <div class="demo-metrics">
                                <div class="metric">
                                    <span class="metric-value">94%</span>
                                    <span class="metric-label">Progress</span>
                                </div>
                                <div class="metric">
                                    <span class="metric-value">2.4h</span>
                                    <span class="metric-label">Study Time</span>
                                </div>
                                <div class="metric">
                                    <span class="metric-value">8/10</span>
                                    <span class="metric-label">Streak</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="premium-cta">
                <a href="/register" class="btn btn-primary btn-large btn-magnetic premium-cta-btn">Unlock Premium Features</a>
                <p class="premium-note">Join thousands of premium learners transforming their education</p>
                <div class="premium-benefits">
                    <span>✓ 30-day money-back guarantee</span>
                    <span>✓ Cancel anytime</span>
                    <span>✓ Premium support included</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="features">
        <div class="container">
            <div class="features-header">
                <h2 class="section-title core-title">Core Learning Features</h2>
                <p class="section-subtitle core-subtitle">Essential tools that power your learning journey, available to all SmartEdu users.</p>
                <div class="core-stats">
                    <div class="core-stat">
                        <span class="stat-number">10K+</span>
                        <span class="stat-label">Active Users</span>
                    </div>
                    <div class="core-stat">
                        <span class="stat-number">95%</span>
                        <span class="stat-label">User Satisfaction</span>
                    </div>
                    <div class="core-stat">
                        <span class="stat-number">Free</span>
                        <span class="stat-label">Core Access</span>
                    </div>
                </div>
            </div>
            <div class="features-grid">
                <div class="feature-card glass-card core-card">
                    <div class="card-icon core-icon">🎯</div>
                    <h3>Interactive Quizzes</h3>
                    <p>Engage with dynamic quizzes that adapt to your learning pace and provide instant feedback.</p>
                    <div class="core-features-list">
                        <span>Adaptive Difficulty</span>
                        <span>Instant Results</span>
                        <span>Progress Tracking</span>
                    </div>
                </div>
                <div class="feature-card glass-card core-card">
                    <div class="card-icon core-icon">📝</div>
                    <h3>Homework Management</h3>
                    <p>Easily submit and track homework assignments with deadline reminders and progress updates.</p>
                    <div class="core-features-list">
                        <span>Deadline Alerts</span>
                        <span>File Upload</span>
                        <span>Grade Tracking</span>
                    </div>
                </div>
                <div class="feature-card glass-card core-card">
                    <div class="card-icon core-icon">🎥</div>
                    <h3>Video Lectures</h3>
                    <p>Access high-quality video lectures with interactive controls and note-taking capabilities.</p>
                    <div class="core-features-list">
                        <span>HD Quality</span>
                        <span>Note Sync</span>
                        <span>Playback Speed</span>
                    </div>
                </div>
                <div class="feature-card glass-card core-card">
                    <div class="card-icon core-icon">📚</div>
                    <h3>Study Notes</h3>
                    <p>Create, organize, and share comprehensive study notes with multimedia support.</p>
                    <div class="core-features-list">
                        <span>Rich Text Editor</span>
                        <span>Media Support</span>
                        <span>Cloud Sync</span>
                    </div>
                </div>
                <div class="feature-card glass-card core-card">
                    <div class="card-icon core-icon">📊</div>
                    <h3>Performance Analytics</h3>
                    <p>Track your academic progress with detailed analytics and personalized improvement suggestions.</p>
                    <div class="core-features-list">
                        <span>Detailed Reports</span>
                        <span>Progress Charts</span>
                        <span>Study Insights</span>
                    </div>
                </div>
                <div class="feature-card glass-card core-card">
                    <div class="card-icon core-icon">🔔</div>
                    <h3>Real-time Notifications</h3>
                    <p>Stay updated with instant notifications for assignments, grades, and important announcements.</p>
                    <div class="core-features-list">
                        <span>Push Notifications</span>
                        <span>Email Alerts</span>
                        <span>Custom Settings</span>
                    </div>
                </div>
            </div>
            <div class="core-showcase">
                <div class="core-demo">
                    <div class="demo-screen glass-card">
                        <div class="demo-content">
                            <div class="demo-header">
                                <div class="demo-avatar">📚</div>
                                <div class="demo-info">
                                    <div class="demo-name">Core Dashboard</div>
                                    <div class="demo-status">Learning in Progress</div>
                                </div>
                            </div>
                            <div class="demo-metrics">
                                <div class="metric">
                                    <span class="metric-value">85%</span>
                                    <span class="metric-label">Completion</span>
                                </div>
                                <div class="metric">
                                    <span class="metric-value">12</span>
                                    <span class="metric-label">Quizzes Passed</span>
                                </div>
                                <div class="metric">
                                    <span class="metric-value">4.2h</span>
                                    <span class="metric-label">Study Time</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Showcase Section -->
    <section id="showcase" class="showcase">
        <div class="container">
            <div class="showcase-grid">
                <div class="showcase-content">
                    <h2>Immersive Learning Experience</h2>
                    <p>Dive into a world where education meets cinematic artistry. Our dark mode interface creates the perfect environment for deep concentration and knowledge absorption.</p>
                    <div class="showcase-features">
                        <div class="showcase-feature">
                            <i class="fas fa-moon"></i>
                            <span>True Dark Mode</span>
                        </div>
                        <div class="showcase-feature">
                            <i class="fas fa-film"></i>
                            <span>Cinematic Animations</span>
                        </div>
                        <div class="showcase-feature">
                            <i class="fas fa-brain"></i>
                            <span>Neural Learning</span>
                        </div>
                    </div>
                </div>
                <div class="showcase-visual">
                    <div class="floating-mockup showcase-mockup">
                        <div class="mockup-screen showcase-screen"></div>
                        <div class="ambient-glow showcase-glow"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="stats">
        <div class="container">
            <div class="stats-grid">
                <div class="stat-item">
                    <div class="stat-number" data-target="10000">0</div>
                    <div class="stat-label">Active Learners</div>
                    <div class="stat-accent"></div>
                </div>
                <div class="stat-item">
                    <div class="stat-number" data-target="500">0</div>
                    <div class="stat-label">Expert Courses</div>
                    <div class="stat-accent"></div>
                </div>
                <div class="stat-item">
                    <div class="stat-number" data-target="99.9">0</div>
                    <div class="stat-label">Uptime</div>
                    <div class="stat-accent"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- Testimonials Section -->
    <section id="testimonials" class="testimonials">
        <div class="container">
            <h2 class="section-title">What Our Learners Say</h2>
            <div class="testimonials-track">
                <div class="testimonial-card glass-card">
                    <div class="testimonial-content">
                        <p>"The dark mode interface is absolutely stunning. It feels like learning in a high-end cinema. The animations are smooth and the focus is incredible."</p>
                        <div class="testimonial-author">
                            <div class="author-avatar">A</div>
                            <div class="author-info">
                                <div class="author-name">Alex Chen</div>
                                <div class="author-role">Software Engineer</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="testimonial-card glass-card">
                    <div class="testimonial-content">
                        <p>"SmartEdu's cinematic approach to learning has transformed my study habits. The premium feel keeps me engaged for hours."</p>
                        <div class="testimonial-author">
                            <div class="author-avatar">S</div>
                            <div class="author-info">
                                <div class="author-name">Sarah Johnson</div>
                                <div class="author-role">Medical Student</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="testimonial-card glass-card">
                    <div class="testimonial-content">
                        <p>"The attention to detail in the dark mode design is unparalleled. Every interaction feels luxurious and purposeful."</p>
                        <div class="testimonial-author">
                            <div class="author-avatar">M</div>
                            <div class="author-info">
                                <div class="author-name">Marcus Rodriguez</div>
                                <div class="author-role">Data Scientist</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA Section -->
    <section class="final-cta">
        <div class="container">
            <div class="cta-content">
                <h2>Ready to Experience Premium Learning?</h2>
                <p>Join thousands of learners who have discovered the power of cinematic education.</p>
                <a href="/register" class="btn btn-primary btn-large btn-magnetic cta-btn">Start Your Journey</a>
            </div>
        </div>
    </section>

    <!-- Newsletter Section -->
    <section class="newsletter">
        <div class="container">
            <div class="newsletter-content">
                <div class="newsletter-text">
                    <h2>Stay Updated with SmartEdu</h2>
                    <p>Get the latest updates on new features, educational insights, and exclusive premium content delivered to your inbox.</p>
                    <div class="newsletter-features">
                        <span>📧 Weekly Learning Tips</span>
                        <span>🚀 Feature Announcements</span>
                        <span>🎁 Exclusive Discounts</span>
                    </div>
                </div>
                <div class="newsletter-form">
                    <form class="subscribe-form">
                        <div class="form-group">
                            <input type="email" placeholder="Enter your email address" required>
                            <button type="submit" class="btn btn-primary btn-newsletter">
                                <span>Subscribe</span>
                                <i class="fas fa-paper-plane"></i>
                            </button>
                        </div>
                        <p class="privacy-note">We respect your privacy. Unsubscribe at any time.</p>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-brand">
                    <i class="fas fa-graduation-cap"></i>
                    <span>SmartEdu</span>
                </div>
                <div class="footer-links">
                    <a href="#features">Features</a>
                    <a href="#showcase">Showcase</a>
                    <a href="#testimonials">Testimonials</a>
                    <a href="/login">Login</a>
                    <a href="/register">Register</a>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2024 SmartEdu. All rights reserved. Cinematic Learning for the Modern Era.</p>
            </div>
        </div>
    </footer>

    <script src="/js/script.js"></script>
</body>
</html>
