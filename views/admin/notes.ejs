<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notes - <%= chapter.title %> - SmartEdu Admin</title>
    <link rel="stylesheet" href="/css/unified.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --primary: #6366f1;
            --primary-light: #818cf8;
            --primary-dark: #4f46e5;
            --secondary: #ec4899;
            --success: #10b981;
            --success-light: #34d399;
            --warning: #f59e0b;
            --warning-light: #fbbf24;
            --error: #ef4444;
            --error-light: #f87171;
            --info: #3b82f6;
            --dark: #0f172a;
            --dark-2: #1e293b;
            --dark-3: #334155;
            --gray: #64748b;
            --gray-light: #94a3b8;
            --white: #f8fafc;
        }
        body {
            font-family: 'Inter', 'Poppins', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);
            min-height: 100vh;
            color: var(--white);
            overflow-x: hidden;
        }
        .bg-effects { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0; overflow: hidden; }
        .orb { position: absolute; border-radius: 50%; filter: blur(80px); }
        .orb-1 { width: 500px; height: 500px; background: radial-gradient(circle, rgba(16, 185, 129, 0.4) 0%, transparent 70%); top: -150px; left: -150px; animation: pulse 8s ease-in-out infinite; }
        .orb-2 { width: 400px; height: 400px; background: radial-gradient(circle, rgba(236, 72, 153, 0.3) 0%, transparent 70%); bottom: -100px; right: -100px; animation: pulse 10s ease-in-out infinite reverse; }
        .orb-3 { width: 300px; height: 300px; background: radial-gradient(circle, rgba(99, 102, 241, 0.3) 0%, transparent 70%); top: 50%; left: 50%; transform: translate(-50%, -50%); animation: pulse 12s ease-in-out infinite; }
        @keyframes pulse { 0%, 100% { transform: scale(1); opacity: 0.6; } 50% { transform: scale(1.1); opacity: 0.8; } }
        .header { position: fixed; top: 0; left: 0; right: 0; height: 70px; background: rgba(15, 23, 42, 0.95); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(16, 185, 129, 0.2); display: flex; align-items: center; justify-content: space-between; padding: 0 2.5rem; z-index: 1000; }
        .header-brand { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; }
        .header-brand-icon { width: 42px; height: 42px; background: linear-gradient(135deg, var(--success) 0%, var(--primary) 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; box-shadow: 0 4px 20px rgba(16, 185, 129, 0.4); }
        .header-brand-text { font-size: 1.35rem; font-weight: 700; background: linear-gradient(135deg, #fff 0%, var(--success-light) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .header-nav { display: flex; align-items: center; gap: 0.5rem; }
        .header-nav-link { display: flex; align-items: center; gap: 0.5rem; padding: 0.6rem 1.2rem; border-radius: 10px; text-decoration: none; color: var(--gray-light); font-weight: 500; font-size: 0.9rem; transition: all 0.3s ease; }
        .header-nav-link:hover { color: var(--white); background: rgba(16, 185, 129, 0.1); }
        .header-nav-link.active { color: var(--white); background: linear-gradient(135deg, rgba(16, 185, 129, 0.2) 0%, rgba(99, 102, 241, 0.15) 100%); border: 1px solid rgba(16, 185, 129, 0.3); }
        .main { padding-top: 90px; padding-bottom: 3rem; min-height: 100vh; position: relative; z-index: 1; }
        .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
        .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem; }
        .page-title-section { animation: fadeInDown 0.6s ease; }
        @keyframes fadeInDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
        .page-title-icon { width: 70px; height: 70px; background: linear-gradient(135deg, var(--warning) 0%, var(--error) 100%); border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 1.75rem; margin: 0 auto 1rem; box-shadow: 0 8px 30px rgba(245, 158, 11, 0.4); }
        .page-title { font-size: 2.25rem; font-weight: 700; color: var(--white); margin-bottom: 0.5rem; }
        .page-subtitle { color: var(--gray-light); font-size: 1rem; }
        .btn { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.9rem 1.75rem; border-radius: 12px; font-weight: 600; font-size: 0.9rem; cursor: pointer; transition: all 0.3s ease; border: none; text-decoration: none; font-family: inherit; }
        .btn-primary { background: linear-gradient(135deg, var(--success), var(--primary-dark)); color: var(--white); box-shadow: 0 4px 20px rgba(16, 185, 129, 0.4); }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(16, 185, 129, 0.5); }
        .btn-secondary { background: rgba(148, 163, 184, 0.1); color: var(--gray-light); border: 1px solid rgba(148, 163, 184, 0.2); }
        .btn-secondary:hover { background: rgba(148, 163, 184, 0.2); color: var(--white); }
        .btn-danger { background: rgba(239, 68, 68, 0.2); color: var(--error-light); border: 1px solid rgba(239, 68, 68, 0.3); }
        .btn-danger:hover { background: rgba(239, 68, 68, 0.3); }
        .btn-sm { padding: 0.5rem 1rem; font-size: 0.8rem; }
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
        .stat-card { background: rgba(30, 41, 59, 0.6); border: 1px solid rgba(16, 185, 129, 0.15); border-radius: 16px; padding: 1.5rem; display: flex; align-items: center; gap: 1rem; backdrop-filter: blur(10px); }
        .stat-icon { width: 50px; height: 50px; background: linear-gradient(135deg, var(--warning), var(--error)); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; }
        .stat-data h3 { font-size: 1.75rem; font-weight: 700; color: var(--white); }
        .stat-data p { color: var(--gray-light); font-size: 0.875rem; }
        .upload-card { background: rgba(30, 41, 59, 0.6); border: 1px solid rgba(16, 185, 129, 0.15); border-radius: 20px; padding: 2rem; backdrop-filter: blur(20px); margin-bottom: 2rem; }
        .upload-area { border: 2px dashed rgba(245, 158, 11, 0.4); border-radius: 16px; padding: 2.5rem; text-align: center; cursor: pointer; transition: all 0.3s ease; background: rgba(15, 23, 42, 0.4); }
        .upload-area:hover { border-color: var(--warning); background: rgba(245, 158, 11, 0.05); }
        .upload-area.dragover { border-color: var(--warning); background: rgba(245, 158, 11, 0.1); }
        .upload-icon { font-size: 3rem; color: var(--warning); margin-bottom: 0.75rem; }
        .upload-area h3 { color: var(--white); margin-bottom: 0.25rem; font-size: 1.25rem; }
        .upload-area p { color: var(--gray-light); font-size: 0.9rem; }
        .upload-area input[type="file"] { display: none; }
        .file-info { display: none; margin-top: 1.5rem; padding: 1rem; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3); border-radius: 12px; }
        .file-info.active { display: flex; align-items: center; justify-content: space-between; }
        .file-info-left { display: flex; align-items: center; gap: 0.75rem; }
        .file-info-icon { width: 40px; height: 40px; background: var(--error); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--white); }
        .file-info-name { color: var(--white); font-weight: 500; }
        .file-info-size { color: var(--gray-light); font-size: 0.8rem; }
        .file-info-remove { background: none; border: none; color: var(--error); cursor: pointer; padding: 0.5rem; font-size: 1.1rem; }
        .form-row { display: grid; grid-template-columns: 1fr auto; gap: 1rem; margin-top: 1.5rem; }
        .form-input { padding: 0.875rem 1rem; background: rgba(15, 23, 42, 0.7); border: 1.5px solid rgba(16, 185, 129, 0.15); border-radius: 10px; color: var(--white); font-size: 0.9rem; font-family: inherit; transition: all 0.3s ease; }
        .form-input:focus { outline: none; border-color: var(--success); box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.15); }
        .form-input::placeholder { color: var(--gray); }
        .notes-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }
        .note-card { background: rgba(30, 41, 59, 0.6); border: 1px solid rgba(16, 185, 129, 0.15); border-radius: 20px; padding: 1.5rem; backdrop-filter: blur(20px); transition: all 0.3s ease; animation: fadeInUp 0.6s ease backwards; }
        .note-card:hover { transform: translateY(-4px); border-color: var(--warning); box-shadow: 0 10px 40px rgba(245, 158, 11, 0.2); }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        .note-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; }
        .note-icon { width: 50px; height: 50px; background: linear-gradient(135deg, var(--error), var(--warning)); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; color: var(--white); }
        .note-title { font-size: 1.1rem; font-weight: 600; color: var(--white); flex: 1; }
        .note-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }
        .delete-form { display: inline; }
        @media (max-width: 768px) { 
            .header { padding: 0 1rem; } 
            .header-nav-link span { display: none; } 
            .main { padding-top: 80px; } 
            .page-title { font-size: 1.75rem; }
            .notes-grid { grid-template-columns: 1fr; }
            .form-row { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="bg-effects">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
    </div>
    <header class="header">
        <a href="/admin" class="header-brand">
            <div class="header-brand-icon"><i class="fas fa-shield-alt"></i></div>
            <span class="header-brand-text">SmartEdu Admin</span>
        </a>
        <nav class="header-nav">
            <a href="/admin" class="header-nav-link"><i class="fas fa-tachometer-alt"></i><span>Dashboard</span></a>
            <a href="/admin/homework" class="header-nav-link"><i class="fas fa-book"></i><span>Homework</span></a>
            <a href="/admin/send-notification" class="header-nav-link"><i class="fas fa-paper-plane"></i><span>Notifications</span></a>
            <a href="/logout" class="header-nav-link"><i class="fas fa-sign-out-alt"></i><span>Logout</span></a>
        </nav>
    </header>
    <main class="main">
        <div class="container">
            <div class="page-header">
                <div class="page-title-section">
                    <div class="page-title-icon"><i class="fas fa-file-pdf"></i></div>
                    <h1 class="page-title">Notes</h1>
                    <p class="page-subtitle"><%= chapter.title %> - Upload and manage study notes</p>
                </div>
                <a href="/admin/chapters/<%= chapter.subject %>" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back to Chapters</a>
            </div>
            
            <!-- Stats -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-file-pdf"></i></div>
                    <div class="stat-data">
                        <h3><%= notes.length %></h3>
                        <p>Total Notes</p>
                    </div>
                </div>
            </div>
            
            <!-- Upload Section -->
            <div class="upload-card">
                <form method="POST" action="/admin/add-note" enctype="multipart/form-data" id="uploadForm">
                    <input type="hidden" name="chapterId" value="<%= chapter._id %>">
                    <div class="upload-area" id="uploadArea">
                        <input type="file" name="pdf" id="fileInput" accept=".pdf" required>
                        <div class="upload-content">
                            <i class="fas fa-cloud-upload-alt upload-icon"></i>
                            <h3>Drag & Drop Your PDF File</h3>
                            <p>or <span class="upload-link">browse to choose a file</span></p>
                            <p style="font-size: 0.75rem; margin-top: 0.5rem; color: var(--gray);">Supported: PDF files only (max 10MB)</p>
                        </div>
                    </div>
                    <div class="file-info" id="fileInfo">
                        <div class="file-info-left">
                            <div class="file-info-icon"><i class="fas fa-file-pdf"></i></div>
                            <div>
                                <div class="file-info-name" id="fileName"></div>
                                <div class="file-info-size" id="fileSize"></div>
                            </div>
                        </div>
                        <button type="button" class="file-info-remove" id="removeFile"><i class="fas fa-times"></i></button>
                    </div>
                    <div class="form-row">
                        <input type="text" name="title" id="noteTitle" class="form-input" placeholder="Enter note title..." required>
                        <button type="submit" id="uploadBtn" class="btn btn-primary" disabled>
                            <i class="fas fa-upload"></i> Upload Note
                        </button>
                    </div>
                </form>
            </div>
            
            <!-- Notes Grid -->
            <div class="notes-grid">
                <% notes.forEach(function(note, index) { %>
                <div class="note-card" style="animation-delay: <%= index * 0.1 %>s;">
                    <div class="note-header">
                        <div class="note-icon"><i class="fas fa-file-pdf"></i></div>
                        <div class="note-title"><%= note.title %></div>
                    </div>
                    <div class="note-actions">
                        <a href="/uploads/notes/<%= note.file %>" target="_blank" class="btn btn-primary btn-sm">
                            <i class="fas fa-eye"></i> View
                        </a>
                        <form method="POST" action="/admin/delete-note/<%= note._id %>" class="delete-form" onsubmit="return confirm('Delete this note?');">
                            <button type="submit" class="btn btn-danger btn-sm">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </form>
                    </div>
                </div>
                <% }); %>
            </div>
        </div>
    </main>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const uploadArea = document.getElementById('uploadArea');
            const fileInput = document.getElementById('fileInput');
            const fileInfo = document.getElementById('fileInfo');
            const fileName = document.getElementById('fileName');
            const fileSize = document.getElementById('fileSize');
            const removeFile = document.getElementById('removeFile');
            const uploadBtn = document.getElementById('uploadBtn');
            const noteTitle = document.getElementById('noteTitle');
            const uploadLink = document.querySelector('.upload-link');
            let selectedFile = null;

            uploadArea.addEventListener('click', function(e) {
                if (e.target !== removeFile) fileInput.click();
            });

            uploadLink.addEventListener('click', function(e) {
                e.stopPropagation();
                fileInput.click();
            });

            uploadArea.addEventListener('dragover', function(e) {
                e.preventDefault();
                uploadArea.classList.add('dragover');
            });

            uploadArea.addEventListener('dragleave', function(e) {
                e.preventDefault();
                uploadArea.classList.remove('dragover');
            });

            uploadArea.addEventListener('drop', function(e) {
                e.preventDefault();
                uploadArea.classList.remove('dragover');
                if (e.dataTransfer.files.length > 0) handleFileSelect(e.dataTransfer.files[0]);
            });

            fileInput.addEventListener('change', function(e) {
                if (e.target.files.length > 0) handleFileSelect(e.target.files[0]);
            });

            removeFile.addEventListener('click', function() {
                selectedFile = null;
                fileInput.value = '';
                fileInfo.classList.remove('active');
                uploadBtn.disabled = true;
                noteTitle.value = '';
            });

            noteTitle.addEventListener('input', function() {
                uploadBtn.disabled = !selectedFile || !this.value.trim();
            });

            function handleFileSelect(file) {
                if (file.type !== 'application/pdf') {
                    alert('Please select a PDF file only.');
                    return;
                }
                if (file.size > 10 * 1024 * 1024) {
                    alert('File size must be less than 10MB.');
                    return;
                }
                selectedFile = file;
                fileName.textContent = file.name;
                fileSize.textContent = formatFileSize(file.size);
                fileInfo.classList.add('active');
                if (!noteTitle.value.trim()) {
                    noteTitle.value = file.name.replace('.pdf', '');
                }
                uploadBtn.disabled = !noteTitle.value.trim();
            }

            function formatFileSize(bytes) {
                if (bytes === 0) return '0 Bytes';
                const k = 1024;
                const sizes = ['Bytes', 'KB', 'MB', 'GB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
            }
        });
    </script>
</body>
</html>
