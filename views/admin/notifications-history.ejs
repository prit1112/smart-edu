<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notification History - SmartEdu Admin</title>
    <link rel="stylesheet" href="/css/unified.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --primary: #6366f1;
            --primary-light: #818cf8;
            --primary-dark: #4f46e5;
            --secondary: #ec4899;
            --success: #10b981;
            --success-light: #34d399;
            --warning: #f59e0b;
            --warning-light: #fbbf24;
            --error: #ef4444;
            --error-light: #f87171;
            --info: #3b82f6;
            --dark: #0f172a;
            --dark-2: #1e293b;
            --dark-3: #334155;
            --gray: #64748b;
            --gray-light: #94a3b8;
            --white: #f8fafc;
        }
        body {
            font-family: 'Inter', 'Poppins', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);
            min-height: 100vh;
            color: var(--white);
            overflow-x: hidden;
        }
        .bg-effects { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0; overflow: hidden; }
        .orb { position: absolute; border-radius: 50%; filter: blur(80px); }
        .orb-1 { width: 500px; height: 500px; background: radial-gradient(circle, rgba(99, 102, 241, 0.4) 0%, transparent 70%); top: -150px; left: -150px; animation: pulse 8s ease-in-out infinite; }
        .orb-2 { width: 400px; height: 400px; background: radial-gradient(circle, rgba(236, 72, 153, 0.3) 0%, transparent 70%); bottom: -100px; right: -100px; animation: pulse 10s ease-in-out infinite reverse; }
        .orb-3 { width: 300px; height: 300px; background: radial-gradient(circle, rgba(16, 185, 129, 0.3) 0%, transparent 70%); top: 50%; left: 50%; transform: translate(-50%, -50%); animation: pulse 12s ease-in-out infinite; }
        @keyframes pulse { 0%, 100% { transform: scale(1); opacity: 0.6; } 50% { transform: scale(1.1); opacity: 0.8; } }
        .header { position: fixed; top: 0; left: 0; right: 0; height: 70px; background: rgba(15, 23, 42, 0.95); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(99, 102, 241, 0.2); display: flex; align-items: center; justify-content: space-between; padding: 0 2.5rem; z-index: 1000; }
        .header-brand { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; }
        .header-brand-icon { width: 42px; height: 42px; background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; box-shadow: 0 4px 20px rgba(99, 102, 241, 0.4); }
        .header-brand-text { font-size: 1.35rem; font-weight: 700; background: linear-gradient(135deg, #fff 0%, var(--primary-light) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .header-nav { display: flex; align-items: center; gap: 0.5rem; }
        .header-nav-link { display: flex; align-items: center; gap: 0.5rem; padding: 0.6rem 1.2rem; border-radius: 10px; text-decoration: none; color: var(--gray-light); font-weight: 500; font-size: 0.9rem; transition: all 0.3s ease; position: relative; }
        .header-nav-link:hover { color: var(--white); background: rgba(99, 102, 241, 0.1); }
        .header-nav-link.active { color: var(--white); background: linear-gradient(135deg, rgba(99, 102, 241, 0.2) 0%, rgba(236, 72, 153, 0.15) 100%); border: 1px solid rgba(99, 102, 241, 0.3); }
        .main { padding-top: 90px; padding-bottom: 3rem; min-height: 100vh; position: relative; z-index: 1; }
        .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
        .page-title-section { text-align: center; margin-bottom: 2rem; animation: fadeInDown 0.6s ease; }
        @keyframes fadeInDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
        .page-title-icon { width: 70px; height: 70px; background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 1.75rem; margin: 0 auto 1rem; box-shadow: 0 8px 30px rgba(99, 102, 241, 0.4); }
        .page-title { font-size: 2.25rem; font-weight: 700; color: var(--white); margin-bottom: 0.5rem; }
        .page-subtitle { color: var(--gray-light); font-size: 1rem; }
        
        /* Stats Row */
        .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 2rem; }
        @media (max-width: 1024px) { .stats-row { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 640px) { .stats-row { grid-template-columns: 1fr; } }
        .stat-box { background: rgba(30, 41, 59, 0.6); border: 1px solid rgba(99, 102, 241, 0.15); border-radius: 16px; padding: 1.25rem; display: flex; align-items: center; gap: 1rem; transition: all 0.3s ease; animation: fadeInUp 0.5s ease backwards; }
        .stat-box:nth-child(1) { animation-delay: 0.1s; } .stat-box:nth-child(2) { animation-delay: 0.2s; } .stat-box:nth-child(3) { animation-delay: 0.3s; } .stat-box:nth-child(4) { animation-delay: 0.4s; }
        .stat-box:hover { transform: translateY(-3px); border-color: rgba(99, 102, 241, 0.4); box-shadow: 0 10px 40px rgba(99, 102, 241, 0.2); }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        .stat-icon { width: 52px; height: 52px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.35rem; }
        .stat-icon.primary { background: linear-gradient(135deg, rgba(99, 102, 241, 0.25), rgba(99, 102, 241, 0.1)); color: var(--primary-light); }
        .stat-icon.success { background: linear-gradient(135deg, rgba(16, 185, 129, 0.25), rgba(16, 185, 129, 0.1)); color: var(--success); }
        .stat-icon.warning { background: linear-gradient(135deg, rgba(245, 158, 11, 0.25), rgba(245, 158, 11, 0.1)); color: var(--warning); }
        .stat-icon.error { background: linear-gradient(135deg, rgba(239, 68, 68, 0.25), rgba(239, 68, 68, 0.1)); color: var(--error); }
        .stat-info h3 { font-size: 1.65rem; font-weight: 700; color: var(--white); line-height: 1; margin-bottom: 0.25rem; }
        .stat-info p { font-size: 0.8rem; color: var(--gray-light); text-transform: uppercase; letter-spacing: 0.05em; }

        /* Filters Section */
        .filters-section { background: rgba(30, 41, 59, 0.6); border: 1px solid rgba(99, 102, 241, 0.15); border-radius: 16px; padding: 1.5rem; margin-bottom: 1.5rem; backdrop-filter: blur(20px); }
        .filters-form { display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-end; }
        .filter-group { display: flex; flex-direction: column; gap: 0.5rem; flex: 1; min-width: 150px; }
        .filter-group label { font-size: 0.85rem; color: var(--gray-light); font-weight: 500; }
        .filter-input, .filter-select { background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(99, 102, 241, 0.2); border-radius: 10px; padding: 0.75rem 1rem; color: var(--white); font-size: 0.9rem; outline: none; transition: all 0.3s ease; width: 100%; font-family: inherit; }
        .filter-input:focus, .filter-select:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1); }
        .filter-input::placeholder { color: var(--gray); }
        .filter-actions { display: flex; gap: 0.5rem; align-items: flex-end; }
        .btn-filter { padding: 0.75rem 1.25rem; border-radius: 10px; font-weight: 600; font-size: 0.9rem; cursor: pointer; transition: all 0.3s ease; border: none; display: inline-flex; align-items: center; gap: 0.5rem; font-family: inherit; }
        .btn-search { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: var(--white); }
        .btn-search:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(99, 102, 241, 0.4); }
        .btn-clear { background: rgba(148, 163, 184, 0.1); color: var(--gray-light); border: 1px solid rgba(148, 163, 184, 0.2); }
        .btn-clear:hover { background: rgba(148, 163, 184, 0.2); color: var(--white); }

        /* Bulk Actions */
        .bulk-actions { display: flex; align-items: center; gap: 1rem; padding: 1rem 1.5rem; background: rgba(30, 41, 59, 0.6); border: 1px solid rgba(99, 102, 241, 0.15); border-radius: 16px; margin-bottom: 1.5rem; }
        .bulk-checkbox { width: 20px; height: 20px; cursor: pointer; accent-color: var(--primary); }
        .selected-count { color: var(--gray-light); font-size: 0.9rem; }
        .btn-bulk-delete { padding: 0.6rem 1rem; border-radius: 8px; font-weight: 600; font-size: 0.85rem; cursor: pointer; transition: all 0.3s ease; border: none; display: inline-flex; align-items: center; gap: 0.5rem; font-family: inherit; background: rgba(239, 68, 68, 0.1); color: var(--error-light); border: 1px solid rgba(239, 68, 68, 0.2); }
        .btn-bulk-delete:hover { background: rgba(239, 68, 68, 0.2); border-color: rgba(239, 68, 68, 0.4); }
        .btn-bulk-delete:disabled { opacity: 0.5; cursor: not-allowed; }

        /* Notifications List */
        .notifications-list { background: rgba(30, 41, 59, 0.6); border: 1px solid rgba(99, 102, 241, 0.15); border-radius: 20px; padding: 2rem; backdrop-filter: blur(20px); animation: fadeInUp 0.6s ease 0.2s backwards; }
        .notification-card { display: flex; align-items: flex-start; gap: 1rem; padding: 1.25rem; background: rgba(15, 23, 42, 0.6); border: 1px solid rgba(99, 102, 241, 0.1); border-radius: 14px; margin-bottom: 1rem; transition: all 0.3s ease; }
        .notification-card:hover { background: rgba(15, 23, 42, 0.8); border-color: rgba(99, 102, 241, 0.3); }
        .notification-card:last-child { margin-bottom: 0; }
        .notification-checkbox { width: 20px; height: 20px; cursor: pointer; accent-color: var(--primary); margin-top: 0.25rem; flex-shrink: 0; }
        .notification-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; flex-shrink: 0; }
        .notification-icon.info { background: linear-gradient(135deg, rgba(59, 130, 246, 0.2), rgba(59, 130, 246, 0.1)); color: var(--info); }
        .notification-icon.warning { background: linear-gradient(135deg, rgba(245, 158, 11, 0.2), rgba(245, 158, 11, 0.1)); color: var(--warning); }
        .notification-icon.urgent { background: linear-gradient(135deg, rgba(239, 68, 68, 0.2), rgba(239, 68, 68, 0.1)); color: var(--error); }
        .notification-content { flex: 1; }
        .notification-title { font-weight: 600; color: var(--white); font-size: 1rem; margin-bottom: 0.375rem; }
        .notification-message { color: var(--gray-light); font-size: 0.875rem; line-height: 1.5; margin-bottom: 0.5rem; }
        .notification-meta { display: flex; align-items: center; gap: 1rem; font-size: 0.75rem; color: var(--gray); flex-wrap: wrap; }
        .notification-meta span { display: flex; align-items: center; gap: 0.375rem; }
        .notification-target { display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.25rem 0.625rem; background: rgba(99, 102, 241, 0.15); border-radius: 6px; color: var(--primary-light); font-size: 0.75rem; font-weight: 500; }
        .notification-actions { display: flex; align-items: center; gap: 0.5rem; margin-left: auto; }
        .btn-delete { display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 8px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: var(--error-light); cursor: pointer; transition: all 0.3s ease; text-decoration: none; }
        .btn-delete:hover { background: rgba(239, 68, 68, 0.2); border-color: rgba(239, 68, 68, 0.4); }

        /* Empty State */
        .empty-state { text-align: center; padding: 4rem 2rem; }
        .empty-icon { font-size: 4rem; color: var(--gray); margin-bottom: 1rem; }
        .empty-title { font-size: 1.25rem; font-weight: 600; color: var(--white); margin-bottom: 0.5rem; }
        .empty-text { color: var(--gray-light); font-size: 0.875rem; }

        /* Pagination */
        .pagination-section { display: flex; justify-content: space-between; align-items: center; margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid rgba(99, 102, 241, 0.1); flex-wrap: wrap; gap: 1rem; }
        .pagination-info { color: var(--gray-light); font-size: 0.9rem; }
        .pagination-controls { display: flex; gap: 0.5rem; align-items: center; }
        .pagination-btn { padding: 0.5rem 1rem; border-radius: 8px; font-weight: 500; font-size: 0.85rem; cursor: pointer; transition: all 0.3s ease; border: 1px solid rgba(99, 102, 241, 0.2); background: rgba(30, 41, 59, 0.8); color: var(--gray-light); text-decoration: none; display: inline-flex; align-items: center; gap: 0.375rem; }
        .pagination-btn:hover:not(:disabled) { background: rgba(99, 102, 241, 0.1); border-color: var(--primary); color: var(--white); }
        .pagination-btn:disabled { opacity: 0.5; cursor: not-allowed; }
        .pagination-btn.active { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: var(--white); border-color: var(--primary); }
        .page-numbers { display: flex; gap: 0.375rem; }

        /* Form Actions */
        .form-actions { display: flex; gap: 0.75rem; margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid rgba(99, 102, 241, 0.1); }
        .btn { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.9rem 1.75rem; border-radius: 12px; font-weight: 600; font-size: 0.9rem; cursor: pointer; transition: all 0.3s ease; border: none; text-decoration: none; font-family: inherit; }
        .btn-primary { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: var(--white); box-shadow: 0 4px 20px rgba(99, 102, 241, 0.4); flex: 1; }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(99, 102, 241, 0.5); }
        .btn-secondary { background: rgba(148, 163, 184, 0.1); color: var(--gray-light); border: 1px solid rgba(148, 163, 184, 0.2); }
        .btn-secondary:hover { background: rgba(148, 163, 184, 0.2); color: var(--white); }

        /* Responsive */
        @media (max-width: 768px) { 
            .header { padding: 0 1rem; } 
            .header-nav-link span { display: none; } 
            .main { padding-top: 80px; } 
            .page-title { font-size: 1.75rem; } 
            .notification-card { flex-direction: column; } 
            .notification-actions { margin-left: 0; margin-top: 1rem; } 
            .filters-form { flex-direction: column; }
            .filter-group { width: 100%; }
            .bulk-actions { flex-direction: column; align-items: flex-start; }
        }
    </style>
</head>
<body>
    <div class="bg-effects">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
    </div>
    <header class="header">
        <a href="/admin" class="header-brand">
            <div class="header-brand-icon"><i class="fas fa-shield-alt"></i></div>
            <span class="header-brand-text">SmartEdu Admin</span>
        </a>
        <nav class="header-nav">
            <a href="/admin" class="header-nav-link"><i class="fas fa-tachometer-alt"></i><span>Dashboard</span></a>
            <a href="/admin/send-notification" class="header-nav-link"><i class="fas fa-paper-plane"></i><span>Send Notification</span></a>
            <a href="/admin/notifications/history" class="header-nav-link active"><i class="fas fa-history"></i><span>History</span></a>
            <a href="/admin/homework" class="header-nav-link"><i class="fas fa-book"></i><span>Homework</span></a>
            <a href="/logout" class="header-nav-link"><i class="fas fa-sign-out-alt"></i><span>Logout</span></a>
        </nav>
    </header>
    <main class="main">
        <div class="container">
            <div class="page-title-section">
                <div class="page-title-icon"><i class="fas fa-history"></i></div>
                <h1 class="page-title">Notification History</h1>
                <p class="page-subtitle">View, search, filter and manage all sent notifications</p>
            </div>

            <!-- Stats Row -->
            <div class="stats-row">
                <div class="stat-box">
                    <div class="stat-icon primary"><i class="fas fa-bell"></i></div>
                    <div class="stat-info"><h3><%= totalNotifications || 0 %></h3><p>Total Sent</p></div>
                </div>
                <div class="stat-box">
                    <div class="stat-icon info"><i class="fas fa-info-circle"></i></div>
                    <div class="stat-info"><h3><%= infoCount || 0 %></h3><p>Info</p></div>
                </div>
                <div class="stat-box">
                    <div class="stat-icon warning"><i class="fas fa-exclamation-triangle"></i></div>
                    <div class="stat-info"><h3><%= warningCount || 0 %></h3><p>Warning</p></div>
                </div>
                <div class="stat-box">
                    <div class="stat-icon error"><i class="fas fa-exclamation-circle"></i></div>
                    <div class="stat-info"><h3><%= urgentCount || 0 %></h3><p>Urgent</p></div>
                </div>
            </div>

            <!-- Filters Section -->
            <div class="filters-section">
                <form method="GET" action="/admin/notifications/history" class="filters-form">
                    <div class="filter-group" style="flex: 2; min-width: 250px;">
                        <label for="search"><i class="fas fa-search"></i> Search</label>
                        <input type="text" id="search" name="search" class="filter-input" placeholder="Search by title or message..." value="<%= search || '' %>">
                    </div>
                    <div class="filter-group">
                        <label for="type"><i class="fas fa-filter"></i> Type</label>
                        <select id="type" name="type" class="filter-select">
                            <option value="">All Types</option>
                            <option value="info" <%= typeFilter === 'info' ? 'selected' : '' %>>Info</option>
                            <option value="warning" <%= typeFilter === 'warning' ? 'selected' : '' %>>Warning</option>
                            <option value="urgent" <%= typeFilter === 'urgent' ? 'selected' : '' %>>Urgent</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label for="dateFrom"><i class="fas fa-calendar"></i> From Date</label>
                        <input type="date" id="dateFrom" name="dateFrom" class="filter-input" value="<%= dateFrom || '' %>">
                    </div>
                    <div class="filter-group">
                        <label for="dateTo"><i class="fas fa-calendar"></i> To Date</label>
                        <input type="date" id="dateTo" name="dateTo" class="filter-input" value="<%= dateTo || '' %>">
                    </div>
                    <div class="filter-actions">
                        <button type="submit" class="btn-filter btn-search"><i class="fas fa-search"></i> Filter</button>
                        <a href="/admin/notifications/history" class="btn-filter btn-clear"><i class="fas fa-times"></i> Clear</a>
                    </div>
                </form>
            </div>

            <!-- Bulk Actions -->
            <% if (notifications && notifications.length > 0) { %>
            <div class="bulk-actions">
                <input type="checkbox" id="selectAll" class="bulk-checkbox" onchange="toggleSelectAll()">
                <span class="selected-count">Selected: <span id="selectedCount">0</span></span>
                <button type="button" id="bulkDeleteBtn" class="btn-bulk-delete" onclick="bulkDelete()" disabled>
                    <i class="fas fa-trash"></i> Delete Selected
                </button>
            </div>
            <% } %>

            <!-- Notifications List -->
            <div class="notifications-list">
                <% if (notifications && notifications.length > 0) { %>
                    <% notifications.forEach(function(notification) { %>
                        <div class="notification-card">
                            <input type="checkbox" class="notification-checkbox" value="<%= notification._id %>" onchange="updateSelectedCount()">
                            <div class="notification-icon <%= notification.type %>">
                                <i class="fas <%= notification.type === 'urgent' ? 'fa-exclamation-circle' : notification.type === 'warning' ? 'fa-exclamation-triangle' : 'fa-info-circle' %>"></i>
                            </div>
                            <div class="notification-content">
                                <h3 class="notification-title"><%= notification.title %></h3>
                                <p class="notification-message"><%= notification.message %></p>
                                <div class="notification-meta">
                                    <span><i class="fas fa-clock"></i> <%= new Date(notification.createdAt).toLocaleString() %></span>
                                    <span><i class="fas fa-user"></i> <%= notification.createdBy ? notification.createdBy.name : 'Admin' %></span>
                                    <span class="notification-target">
                                        <i class="fas <%= notification.target && notification.target.scope === 'all' ? 'fa-users' : notification.target && notification.target.scope === 'class' ? 'fa-school' : 'fa-user' %>"></i>
                                        <%= notification.target && notification.target.scope === 'all' ? 'All Students' : notification.target && notification.target.scope === 'class' ? 'STD ' + (notification.target.classLevels ? notification.target.classLevels.join(', ') : '') : 'Specific Student' %>
                                    </span>
                                </div>
                            </div>
                            <div class="notification-actions">
                                <form method="POST" action="/admin/notifications/delete/<%= notification._id %>" onsubmit="return confirm('Are you sure you want to delete this notification?');" style="display: inline;">
                                    <button type="submit" class="btn-delete" title="Delete Notification">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="empty-state">
                        <div class="empty-icon"><i class="fas fa-bell-slash"></i></div>
                        <h3 class="empty-title">No Notifications Found</h3>
                        <p class="empty-text"><%= search || typeFilter || dateFrom || dateTo ? 'No notifications match your search criteria. Try different filters.' : "You haven't sent any notifications yet. Start by sending a notification to your students." %></p>
                    </div>
                <% } %>

                <!-- Pagination -->
                <% if (totalPages > 1) { %>
                <div class="pagination-section">
                    <div class="pagination-info">
                        Showing <%= ((currentPage - 1) * limit) + 1 %> - <%= Math.min(currentPage * limit, totalNotifications) %> of <%= totalNotifications %> notifications
                    </div>
                    <div class="pagination-controls">
                        <a href="?page=<%= Math.max(1, currentPage - 1) %><%= search ? '&search=' + search : '' %><%= typeFilter ? '&type=' + typeFilter : '' %><%= dateFrom ? '&dateFrom=' + dateFrom : '' %><%= dateTo ? '&dateTo=' + dateTo : '' %>" class="pagination-btn <%= currentPage === 1 ? 'disabled' : '' %>" <%= currentPage === 1 ? 'disabled' : '' %>>
                            <i class="fas fa-chevron-left"></i> Prev
                        </a>
                        <div class="page-numbers">
                            <% for(let i = 1; i <= totalPages; i++) { %>
                                <% if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) { %>
                                    <a href="?page=<%= i %><%= search ? '&search=' + search : '' %><%= typeFilter ? '&type=' + typeFilter : '' %><%= dateFrom ? '&dateFrom=' + dateFrom : '' %><%= dateTo ? '&dateTo=' + dateTo : '' %>" class="pagination-btn <%= i === currentPage ? 'active' : '' %>"><%= i %></a>
                                <% } else if (i === currentPage - 2 || i === currentPage + 2) { %>
                                    <span class="pagination-btn">...</span>
                                <% } %>
                            <% } %>
                        </div>
                        <a href="?page=<%= Math.min(totalPages, currentPage + 1) %><%= search ? '&search=' + search : '' %><%= typeFilter ? '&type=' + typeFilter : '' %><%= dateFrom ? '&dateFrom=' + dateFrom : '' %><%= dateTo ? '&dateTo=' + dateTo : '' %>" class="pagination-btn <%= currentPage === totalPages ? 'disabled' : '' %>" <%= currentPage === totalPages ? 'disabled' : '' %>>
                            Next <i class="fas fa-chevron-right"></i>
                        </a>
                    </div>
                </div>
                <% } %>
            </div>

            <div class="form-actions">
                <a href="/admin/send-notification" class="btn btn-primary"><i class="fas fa-paper-plane"></i> Send New Notification</a>
                <a href="/admin" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back to Dashboard</a>
            </div>
        </div>
    </main>

    <!-- Bulk Delete Form (Hidden) -->
    <form id="bulkDeleteForm" method="POST" action="/admin/notifications/bulk-delete" style="display: none;">
        <input type="hidden" name="notificationIds" id="notificationIdsInput">
    </form>

    <script>
        function toggleSelectAll() {
            const selectAll = document.getElementById('selectAll');
            const checkboxes = document.querySelectorAll('.notification-checkbox');
            checkboxes.forEach(cb => cb.checked = selectAll.checked);
            updateSelectedCount();
        }

        function updateSelectedCount() {
            const checkboxes = document.querySelectorAll('.notification-checkbox:checked');
            const count = checkboxes.length;
            const selectAll = document.getElementById('selectAll');
            const bulkDeleteBtn = document.getElementById('bulkDeleteBtn');
            const selectedCount = document.getElementById('selectedCount');
            
            if (selectedCount) {
                selectedCount.textContent = count;
            }
            
            if (bulkDeleteBtn) {
                bulkDeleteBtn.disabled = count === 0;
            }

            // Update select all checkbox state
            const allCheckboxes = document.querySelectorAll('.notification-checkbox');
            const allChecked = Array.from(allCheckboxes).every(cb => cb.checked);
            const someChecked = Array.from(allCheckboxes).some(cb => cb.checked);
            if (selectAll) {
                selectAll.checked = allChecked;
                selectAll.indeterminate = someChecked && !allChecked;
            }
        }

        function bulkDelete() {
            const checkboxes = document.querySelectorAll('.notification-checkbox:checked');
            const ids = Array.from(checkboxes).map(cb => cb.value);
            
            if (ids.length === 0) {
                alert('Please select at least one notification to delete.');
                return;
            }

            if (confirm(`Are you sure you want to delete ${ids.length} notification(s)? This action cannot be undone.`)) {
                document.getElementById('notificationIdsInput').value = JSON.stringify(ids);
                document.getElementById('bulkDeleteForm').submit();
            }
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            updateSelectedCount();
        });
    </script>
</body>
</html>
