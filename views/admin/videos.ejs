<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Videos - <%= chapter.title %> - SmartEdu Admin</title>
    <link rel="stylesheet" href="/css/unified.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --primary: #6366f1;
            --primary-light: #818cf8;
            --primary-dark: #4f46e5;
            --secondary: #ec4899;
            --success: #10b981;
            --success-light: #34d399;
            --warning: #f59e0b;
            --warning-light: #fbbf24;
            --error: #ef4444;
            --error-light: #f87171;
            --info: #3b82f6;
            --dark: #0f172a;
            --dark-2: #1e293b;
            --dark-3: #334155;
            --gray: #64748b;
            --gray-light: #94a3b8;
            --white: #f8fafc;
        }
        body {
            font-family: 'Inter', 'Poppins', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);
            min-height: 100vh;
            color: var(--white);
            overflow-x: hidden;
        }
        .bg-effects { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0; overflow: hidden; }
        .orb { position: absolute; border-radius: 50%; filter: blur(80px); }
        .orb-1 { width: 500px; height: 500px; background: radial-gradient(circle, rgba(16, 185, 129, 0.4) 0%, transparent 70%); top: -150px; left: -150px; animation: pulse 8s ease-in-out infinite; }
        .orb-2 { width: 400px; height: 400px; background: radial-gradient(circle, rgba(236, 72, 153, 0.3) 0%, transparent 70%); bottom: -100px; right: -100px; animation: pulse 10s ease-in-out infinite reverse; }
        .orb-3 { width: 300px; height: 300px; background: radial-gradient(circle, rgba(99, 102, 241, 0.3) 0%, transparent 70%); top: 50%; left: 50%; transform: translate(-50%, -50%); animation: pulse 12s ease-in-out infinite; }
        @keyframes pulse { 0%, 100% { transform: scale(1); opacity: 0.6; } 50% { transform: scale(1.1); opacity: 0.8; } }
        .header { position: fixed; top: 0; left: 0; right: 0; height: 70px; background: rgba(15, 23, 42, 0.95); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(16, 185, 129, 0.2); display: flex; align-items: center; justify-content: space-between; padding: 0 2.5rem; z-index: 1000; }
        .header-brand { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; }
        .header-brand-icon { width: 42px; height: 42px; background: linear-gradient(135deg, var(--success) 0%, var(--primary) 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; box-shadow: 0 4px 20px rgba(16, 185, 129, 0.4); }
        .header-brand-text { font-size: 1.35rem; font-weight: 700; background: linear-gradient(135deg, #fff 0%, var(--success-light) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .header-nav { display: flex; align-items: center; gap: 0.5rem; }
        .header-nav-link { display: flex; align-items: center; gap: 0.5rem; padding: 0.6rem 1.2rem; border-radius: 10px; text-decoration: none; color: var(--gray-light); font-weight: 500; font-size: 0.9rem; transition: all 0.3s ease; }
        .header-nav-link:hover { color: var(--white); background: rgba(16, 185, 129, 0.1); }
        .header-nav-link.active { color: var(--white); background: linear-gradient(135deg, rgba(16, 185, 129, 0.2) 0%, rgba(99, 102, 241, 0.15) 100%); border: 1px solid rgba(16, 185, 129, 0.3); }
        .main { padding-top: 90px; padding-bottom: 3rem; min-height: 100vh; position: relative; z-index: 1; }
        .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
        .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem; }
        .page-title-section { animation: fadeInDown 0.6s ease; }
        @keyframes fadeInDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
        .page-title-icon { width: 70px; height: 70px; background: linear-gradient(135deg, var(--error) 0%, var(--secondary) 100%); border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 1.75rem; margin: 0 auto 1rem; box-shadow: 0 8px 30px rgba(239, 68, 68, 0.4); }
        .page-title { font-size: 2.25rem; font-weight: 700; color: var(--white); margin-bottom: 0.5rem; }
        .page-subtitle { color: var(--gray-light); font-size: 1rem; }
        .btn { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.9rem 1.75rem; border-radius: 12px; font-weight: 600; font-size: 0.9rem; cursor: pointer; transition: all 0.3s ease; border: none; text-decoration: none; font-family: inherit; }
        .btn-primary { background: linear-gradient(135deg, var(--success), var(--primary-dark)); color: var(--white); box-shadow: 0 4px 20px rgba(16, 185, 129, 0.4); }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(16, 185, 129, 0.5); }
        .btn-secondary { background: rgba(148, 163, 184, 0.1); color: var(--gray-light); border: 1px solid rgba(148, 163, 184, 0.2); }
        .btn-secondary:hover { background: rgba(148, 163, 184, 0.2); color: var(--white); }
        .btn-danger { background: rgba(239, 68, 68, 0.2); color: var(--error-light); border: 1px solid rgba(239, 68, 68, 0.3); }
        .btn-danger:hover { background: rgba(239, 68, 68, 0.3); }
        .btn-sm { padding: 0.5rem 1rem; font-size: 0.8rem; }
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
        .stat-card { background: rgba(30, 41, 59, 0.6); border: 1px solid rgba(16, 185, 129, 0.15); border-radius: 16px; padding: 1.5rem; display: flex; align-items: center; gap: 1rem; backdrop-filter: blur(10px); }
        .stat-icon { width: 50px; height: 50px; background: linear-gradient(135deg, var(--error), var(--secondary)); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; }
        .stat-data h3 { font-size: 1.75rem; font-weight: 700; color: var(--white); }
        .stat-data p { color: var(--gray-light); font-size: 0.875rem; }
        
        /* Add Video Form */
        .add-video-card { background: rgba(30, 41, 59, 0.6); border: 1px solid rgba(16, 185, 129, 0.15); border-radius: 20px; padding: 2rem; backdrop-filter: blur(20px); margin-bottom: 2rem; }
        .form-grid { display: grid; grid-template-columns: 1fr 1fr auto; gap: 1rem; align-items: end; }
        .form-field { margin-bottom: 0; }
        .form-label { display: block; margin-bottom: 0.5rem; font-weight: 500; color: var(--gray-light); font-size: 0.875rem; }
        .form-input { width: 100%; padding: 0.875rem 1rem; background: rgba(15, 23, 42, 0.7); border: 1.5px solid rgba(16, 185, 129, 0.15); border-radius: 10px; color: var(--white); font-size: 0.9rem; font-family: inherit; transition: all 0.3s ease; }
        .form-input:focus { outline: none; border-color: var(--success); box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.15); }
        .form-input::placeholder { color: var(--gray); }
        
        /* Videos Grid */
        .videos-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 1.5rem; }
        .video-card { background: rgba(30, 41, 59, 0.6); border: 1px solid rgba(16, 185, 129, 0.15); border-radius: 20px; padding: 1.5rem; backdrop-filter: blur(20px); transition: all 0.3s ease; animation: fadeInUp 0.6s ease backwards; }
        .video-card:hover { transform: translateY(-4px); border-color: var(--error); box-shadow: 0 10px 40px rgba(239, 68, 68, 0.2); }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        .video-title { font-size: 1.1rem; font-weight: 600; color: var(--white); margin-bottom: 1rem; }
        .video-frame { width: 100%; aspect-ratio: 16/9; border-radius: 12px; overflow: hidden; margin-bottom: 1rem; background: var(--dark); }
        .video-frame iframe { width: 100%; height: 100%; border: none; }
        .video-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }
        
        .delete-form { display: inline; }
        
        @media (max-width: 768px) { 
            .header { padding: 0 1rem; } 
            .header-nav-link span { display: none; } 
            .main { padding-top: 80px; } 
            .page-title { font-size: 1.75rem; }
            .videos-grid { grid-template-columns: 1fr; }
            .form-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="bg-effects">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
    </div>
    <header class="header">
        <a href="/admin" class="header-brand">
            <div class="header-brand-icon"><i class="fas fa-shield-alt"></i></div>
            <span class="header-brand-text">SmartEdu Admin</span>
        </a>
        <nav class="header-nav">
            <a href="/admin" class="header-nav-link"><i class="fas fa-tachometer-alt"></i><span>Dashboard</span></a>
            <a href="/admin/homework" class="header-nav-link"><i class="fas fa-book"></i><span>Homework</span></a>
            <a href="/admin/send-notification" class="header-nav-link"><i class="fas fa-paper-plane"></i><span>Notifications</span></a>
            <a href="/logout" class="header-nav-link"><i class="fas fa-sign-out-alt"></i><span>Logout</span></a>
        </nav>
    </header>
    <main class="main">
        <div class="container">
            <div class="page-header">
                <div class="page-title-section">
                    <div class="page-title-icon"><i class="fas fa-video"></i></div>
                    <h1 class="page-title">Videos</h1>
                    <p class="page-subtitle"><%= chapter.title %> - Manage educational videos</p>
                </div>
                <a href="/admin/chapters/<%= chapter.subject %>" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back to Chapters</a>
            </div>
            
            <!-- Stats -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-video"></i></div>
                    <div class="stat-data">
                        <h3><%= videos.length %></h3>
                        <p>Total Videos</p>
                    </div>
                </div>
            </div>
            
            <!-- Add Video Form -->
            <div class="add-video-card">
                <form method="POST" action="/admin/add-video">
                    <input type="hidden" name="chapterId" value="<%= chapter._id %>">
                    <div class="form-grid">
                        <div class="form-field">
                            <label for="title" class="form-label">Video Title</label>
                            <input type="text" name="title" id="title" class="form-input" placeholder="Enter video title" required>
                        </div>
                        <div class="form-field">
                            <label for="url" class="form-label">YouTube Embed URL</label>
                            <input type="text" name="url" id="url" class="form-input" placeholder="https://www.youtube.com/embed/..." required>
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Add Video
                        </button>
                    </div>
                </form>
            </div>
            
            <!-- Videos Grid -->
            <div class="videos-grid">
                <% videos.forEach(function(video, index) { %>
                <div class="video-card" style="animation-delay: <%= index * 0.1 %>s;">
                    <div class="video-title"><%= video.title %></div>
                    <div class="video-frame">
                        <iframe src="<%= video.url %>" allowfullscreen></iframe>
                    </div>
                    <div class="video-actions">
                        <form method="POST" action="/admin/delete-video/<%= video._id %>" class="delete-form" onsubmit="return confirm('Delete this video?');">
                            <button type="submit" class="btn btn-danger btn-sm">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </form>
                    </div>
                </div>
                <% }); %>
            </div>
        </div>
    </main>
</body>
</html>
