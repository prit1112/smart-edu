<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Homework Details - SmartEdu Admin</title>
    <link rel="stylesheet" href="/css/unified.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --primary: #6366f1;
            --primary-light: #818cf8;
            --primary-dark: #4f46e5;
            --secondary: #ec4899;
            --success: #10b981;
            --success-light: #34d399;
            --warning: #f59e0b;
            --warning-light: #fbbf24;
            --error: #ef4444;
            --error-light: #f87171;
            --info: #3b82f6;
            --dark: #0f172a;
            --dark-2: #1e293b;
            --dark-3: #334155;
            --gray: #64748b;
            --gray-light: #94a3b8;
            --white: #f8fafc;
        }
        body {
            font-family: 'Inter', 'Poppins', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);
            min-height: 100vh;
            color: var(--white);
            overflow-x: hidden;
        }
        .bg-effects { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0; overflow: hidden; }
        .orb { position: absolute; border-radius: 50%; filter: blur(80px); }
        .orb-1 { width: 500px; height: 500px; background: radial-gradient(circle, rgba(16, 185, 129, 0.4) 0%, transparent 70%); top: -150px; left: -150px; animation: pulse 8s ease-in-out infinite; }
        .orb-2 { width: 400px; height: 400px; background: radial-gradient(circle, rgba(236, 72, 153, 0.3) 0%, transparent 70%); bottom: -100px; right: -100px; animation: pulse 10s ease-in-out infinite reverse; }
        .orb-3 { width: 300px; height: 300px; background: radial-gradient(circle, rgba(99, 102, 241, 0.3) 0%, transparent 70%); top: 50%; left: 50%; transform: translate(-50%, -50%); animation: pulse 12s ease-in-out infinite; }
        @keyframes pulse { 0%, 100% { transform: scale(1); opacity: 0.6; } 50% { transform: scale(1.1); opacity: 0.8; } }
        .header { position: fixed; top: 0; left: 0; right: 0; height: 70px; background: rgba(15, 23, 42, 0.95); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(16, 185, 129, 0.2); display: flex; align-items: center; justify-content: space-between; padding: 0 2.5rem; z-index: 1000; }
        .header-brand { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; }
        .header-brand-icon { width: 42px; height: 42px; background: linear-gradient(135deg, var(--success) 0%, var(--primary) 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; box-shadow: 0 4px 20px rgba(16, 185, 129, 0.4); }
        .header-brand-text { font-size: 1.35rem; font-weight: 700; background: linear-gradient(135deg, #fff 0%, var(--success-light) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .header-nav { display: flex; align-items: center; gap: 0.5rem; }
        .header-nav-link { display: flex; align-items: center; gap: 0.5rem; padding: 0.6rem 1.2rem; border-radius: 10px; text-decoration: none; color: var(--gray-light); font-weight: 500; font-size: 0.9rem; transition: all 0.3s ease; position: relative; }
        .header-nav-link:hover { color: var(--white); background: rgba(16, 185, 129, 0.1); }
        .header-nav-link.active { color: var(--white); background: linear-gradient(135deg, rgba(16, 185, 129, 0.2) 0%, rgba(99, 102, 241, 0.15) 100%); border: 1px solid rgba(16, 185, 129, 0.3); }
        .main { padding-top: 90px; padding-bottom: 3rem; min-height: 100vh; position: relative; z-index: 1; }
        .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
        .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem; }
        .page-title-section { animation: fadeInDown 0.6s ease; }
        @keyframes fadeInDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
        .page-title-icon { width: 70px; height: 70px; background: linear-gradient(135deg, var(--success) 0%, var(--primary) 100%); border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 1.75rem; margin: 0 auto 1rem; box-shadow: 0 8px 30px rgba(16, 185, 129, 0.4); }
        .page-title { font-size: 2.25rem; font-weight: 700; color: var(--white); margin-bottom: 0.5rem; }
        .page-subtitle { color: var(--gray-light); font-size: 1rem; }
        .btn { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.9rem 1.75rem; border-radius: 12px; font-weight: 600; font-size: 0.9rem; cursor: pointer; transition: all 0.3s ease; border: none; text-decoration: none; font-family: inherit; }
        .btn-primary { background: linear-gradient(135deg, var(--success), var(--primary-dark)); color: var(--white); box-shadow: 0 4px 20px rgba(16, 185, 129, 0.4); }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(16, 185, 129, 0.5); }
        .btn-secondary { background: rgba(148, 163, 184, 0.1); color: var(--gray-light); border: 1px solid rgba(148, 163, 184, 0.2); }
        .btn-secondary:hover { background: rgba(148, 163, 184, 0.2); color: var(--white); }
        .btn-sm { padding: 0.5rem 1rem; font-size: 0.8rem; }
        .btn-danger { background: rgba(239, 68, 68, 0.2); color: var(--error-light); border: 1px solid rgba(239, 68, 68, 0.3); }
        .btn-danger:hover { background: rgba(239, 68, 68, 0.3); }
        
        /* Info Cards */
        .info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
        .info-card { background: rgba(30, 41, 59, 0.6); border: 1px solid rgba(16, 185, 129, 0.15); border-radius: 16px; padding: 1.25rem; display: flex; align-items: center; gap: 1rem; transition: all 0.3s ease; }
        .info-card:hover { transform: translateY(-3px); border-color: rgba(16, 185, 129, 0.4); }
        .info-icon { width: 50px; height: 50px; background: linear-gradient(135deg, rgba(16, 185, 129, 0.2), rgba(99, 102, 241, 0.15)); border-radius: 12px; display: flex; align-items: center; justify-content: center; color: var(--success-light); font-size: 1.25rem; }
        .info-content h4 { color: var(--gray-light); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem; }
        .info-content p { color: var(--white); font-size: 1.1rem; font-weight: 600; }
        
        /* Content Card */
        .content-card { background: rgba(30, 41, 59, 0.6); border: 1px solid rgba(16, 185, 129, 0.15); border-radius: 20px; padding: 2rem; backdrop-filter: blur(20px); animation: fadeInUp 0.6s ease 0.2s backwards; margin-bottom: 1.5rem; }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        .section-title { font-size: 1.25rem; font-weight: 600; color: var(--white); margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; }
        .section-title i { color: var(--success); }
        .description-text { color: var(--gray-light); line-height: 1.7; white-space: pre-wrap; }
        
        /* Attachments */
        .attachments-list { display: flex; flex-direction: column; gap: 0.75rem; }
        .attachment-link { display: inline-flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1.25rem; background: rgba(15, 23, 42, 0.6); border: 1px solid rgba(16, 185, 129, 0.2); border-radius: 12px; text-decoration: none; color: var(--white); transition: all 0.3s ease; }
        .attachment-link:hover { background: rgba(16, 185, 129, 0.1); border-color: var(--success); transform: translateX(4px); }
        .attachment-link i { color: var(--success); }
        
        /* Submissions Table */
        .submissions-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem; }
        .submission-stat { background: rgba(15, 23, 42, 0.6); border-radius: 12px; padding: 1rem; text-align: center; }
        .submission-stat .number { font-size: 2rem; font-weight: 700; color: var(--white); }
        .submission-stat .label { font-size: 0.75rem; color: var(--gray-light); text-transform: uppercase; letter-spacing: 0.05em; }
        .submission-stat.submitted .number { color: var(--success-light); }
        .submission-stat.pending .number { color: var(--warning-light); }
        .submission-stat.late .number { color: var(--error-light); }
        
        .submissions-table-container { overflow-x: auto; }
        .submissions-table { width: 100%; border-collapse: collapse; }
        .submissions-table th { text-align: left; padding: 1rem; background: rgba(15, 23, 42, 0.8); color: var(--gray-light); font-weight: 600; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid rgba(16, 185, 129, 0.1); }
        .submissions-table th:first-child { border-radius: 12px 0 0 0; }
        .submissions-table th:last-child { border-radius: 0 12px 0 0; }
        .submissions-table td { padding: 1rem; border-bottom: 1px solid rgba(16, 185, 129, 0.1); color: var(--white); }
        .submissions-table tr:hover { background: rgba(16, 185, 129, 0.05); }
        
        .status-badge { display: inline-block; padding: 0.375rem 0.875rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
        .status-badge.submitted { background: rgba(16, 185, 129, 0.2); color: var(--success-light); }
        .status-badge.not-submitted { background: rgba(245, 158, 11, 0.2); color: var(--warning-light); }
        .status-badge.late { background: rgba(239, 68, 68, 0.2); color: var(--error-light); }
        .status-badge.graded { background: rgba(99, 102, 241, 0.2); color: var(--primary-light); }
        
        .empty-state { text-align: center; padding: 3rem; }
        .empty-state i { font-size: 3rem; color: var(--gray); margin-bottom: 1rem; }
        .empty-state p { color: var(--gray-light); }
        
        @media (max-width: 768px) { 
            .header { padding: 0 1rem; } 
            .header-nav-link span { display: none; } 
            .main { padding-top: 80px; } 
            .page-title { font-size: 1.75rem; }
            .submissions-stats { grid-template-columns: repeat(2, 1fr); }
            .page-header { flex-direction: column; align-items: flex-start; }
        }
    </style>
</head>
<body>
    <div class="bg-effects">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
    </div>
    <header class="header">
        <a href="/admin" class="header-brand">
            <div class="header-brand-icon"><i class="fas fa-shield-alt"></i></div>
            <span class="header-brand-text">SmartEdu Admin</span>
        </a>
        <nav class="header-nav">
            <a href="/admin" class="header-nav-link"><i class="fas fa-tachometer-alt"></i><span>Dashboard</span></a>
            <a href="/admin/send-notification" class="header-nav-link"><i class="fas fa-paper-plane"></i><span>Notifications</span></a>
            <a href="/admin/homework" class="header-nav-link active"><i class="fas fa-book"></i><span>Homework</span></a>
            <a href="/logout" class="header-nav-link"><i class="fas fa-sign-out-alt"></i><span>Logout</span></a>
        </nav>
    </header>
    <main class="main">
        <div class="container">
            <div class="page-header">
                <div class="page-title-section">
                    <div class="page-title-icon"><i class="fas fa-book-open"></i></div>
                    <h1 class="page-title"><%= homework.title %></h1>
                    <p class="page-subtitle">Homework Details and Submissions</p>
                </div>
                <div style="display: flex; gap: 0.75rem;">
                    <a href="/admin/homework/<%= homework._id %>/edit" class="btn btn-secondary"><i class="fas fa-edit"></i> Edit</a>
                    <form method="POST" action="/admin/homework/<%= homework._id %>/delete" onsubmit="return confirm('Delete this homework and all submissions?');" style="display: inline;">
                        <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Delete</button>
                    </form>
                    <a href="/admin/homework" class="btn btn-primary"><i class="fas fa-arrow-left"></i> Back</a>
                </div>
            </div>
            
            <!-- Info Cards -->
            <div class="info-grid">
                <div class="info-card">
                    <div class="info-icon"><i class="fas fa-graduation-cap"></i></div>
                    <div class="info-content">
                        <h4>Class</h4>
                        <p>STD <%= homework.classLevel %></p>
                    </div>
                </div>
                <div class="info-card">
                    <div class="info-icon"><i class="fas fa-book"></i></div>
                    <div class="info-content">
                        <h4>Subject</h4>
                        <p><%= homework.subject ? homework.subject.name : 'N/A' %></p>
                    </div>
                </div>
                <div class="info-card">
                    <div class="info-icon"><i class="fas fa-calendar"></i></div>
                    <div class="info-content">
                        <h4>Due Date</h4>
                        <p><%= new Date(homework.dueDate).toLocaleDateString() %></p>
                    </div>
                </div>
                <div class="info-card">
                    <div class="info-icon"><i class="fas fa-star"></i></div>
                    <div class="info-content">
                        <h4>Max Marks</h4>
                        <p><%= homework.maxMarks %></p>
                    </div>
                </div>
            </div>
            
            <!-- Description -->
            <div class="content-card">
                <h3 class="section-title"><i class="fas fa-align-left"></i> Description</h3>
                <p class="description-text"><%= homework.description %></p>
            </div>
            
            <!-- Attachments -->
            <% if (homework.attachments && homework.attachments.length > 0) { %>
                <div class="content-card">
                    <h3 class="section-title"><i class="fas fa-paperclip"></i> Attachments</h3>
                    <div class="attachments-list">
                        <% homework.attachments.forEach(function(file) { %>
                            <a href="/uploads/homework/<%= file %>" target="_blank" class="attachment-link">
                                <i class="fas fa-file"></i>
                                <span><%= file %></span>
                            </a>
                        <% }); %>
                    </div>
                </div>
            <% } %>
            
            <!-- Submissions -->
            <div class="content-card">
                <h3 class="section-title"><i class="fas fa-users"></i> Submissions (<%= validSubmissions.length %>/<%= totalStudents %>)</h3>
                
                <div class="submissions-stats">
                    <div class="submission-stat submitted">
                        <div class="number"><%= validSubmissions.filter(s => s.status === 'submitted' || s.status === 'graded').length %></div>
                        <div class="label">Submitted</div>
                    </div>
                    <div class="submission-stat pending">
                        <div class="number"><%= validSubmissions.filter(s => s.status === 'not_submitted').length %></div>
                        <div class="label">Pending</div>
                    </div>
                    <div class="submission-stat late">
                        <div class="number"><%= validSubmissions.filter(s => s.status === 'late').length %></div>
                        <div class="label">Late</div>
                    </div>
                    <div class="submission-stat">
                        <div class="number"><%= validSubmissions.filter(s => s.marks !== undefined && s.marks !== null).length %></div>
                        <div class="label">Graded</div>
                    </div>
                </div>
                
                <% if (validSubmissions && validSubmissions.length > 0) { %>
                    <div class="submissions-table-container">
                        <table class="submissions-table">
                            <thead>
                                <tr>
                                    <th>Student</th>
                                    <th>Status</th>
                                    <th>Submitted At</th>
                                    <th>Marks</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% validSubmissions.forEach(function(sub) { %>
                                    <% if (sub && sub.student && sub.student.name) { %>
                                        <tr>
                                            <td><%= sub.student.name %></td>
                                            <td><span class="status-badge <%= sub.status %>"><%= sub.status.replace('_', ' ') %></span></td>
                                            <td><%= sub.submittedAt ? new Date(sub.submittedAt).toLocaleString() : '-' %></td>
                                            <td><%= sub.marks !== undefined && sub.marks !== null ? sub.marks + '/' + homework.maxMarks : '-' %></td>
                                            <td>
                                                <% if (sub.status !== 'not_submitted') { %>
                                                    <a href="/admin/homework/submission/<%= sub._id %>" class="btn btn-primary btn-sm">
                                                        <i class="fas fa-eye"></i> View
                                                    </a>
                                                <% } else { %>
                                                    <span style="color: var(--gray);">-</span>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% } %>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="empty-state">
                        <i class="fas fa-inbox"></i>
                        <p>No submissions yet</p>
                    </div>
                <% } %>
            </div>
        </div>
    </main>
</body>
</html>
