<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Homework - SmartEdu</title>
    <link rel="stylesheet" href="/css/unified.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <!-- Bubble Effects -->
    <div class="bubbles">
        <div class="bubble bubble-1"></div>
        <div class="bubble bubble-2"></div>
        <div class="bubble bubble-3"></div>
        <div class="bubble bubble-4"></div>
        <div class="bubble bubble-5"></div>
        <div class="bubble bubble-6"></div>
        <div class="bubble bubble-7"></div>
        <div class="bubble bubble-8"></div>
        <div class="bubble bubble-9"></div>
        <div class="bubble bubble-10"></div>
    </div>

    <div class="homework-page-container">
        <!-- Page Header -->
        <div class="page-header">
            <h1><i class="fas fa-tasks"></i> My Homework</h1>
            <p>Manage and submit your homework assignments</p>
        </div>

        <!-- Stats Overview -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-book"></i></div>
                <div class="stat-data">
                    <h3><%= homeworksWithStatus.length %></h3>
                    <p>Total Homework</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-clock"></i></div>
                <div class="stat-data">
                    <h3><%= homeworksWithStatus.filter(h => h.status === 'pending').length %></h3>
                    <p>Pending</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
                <div class="stat-data">
                    <h3><%= homeworksWithStatus.filter(h => h.status === 'submitted').length %></h3>
                    <p>Submitted</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-exclamation-triangle"></i></div>
                <div class="stat-data">
                    <h3><%= homeworksWithStatus.filter(h => h.status === 'overdue' || h.status === 'late').length %></h3>
                    <p>Overdue</p>
                </div>
            </div>
        </div>

        <!-- Homework List -->
        <section class="section">
            <h2 class="section-title">My Homework Assignments</h2>
            <div class="homework-list">
                <% if (homeworksWithStatus && homeworksWithStatus.length > 0) { %>
                    <% homeworksWithStatus.forEach(function(hw) { %>
                    <div class="homework-item">
                        <div class="homework-info">
                            <h3><%= hw.title %></h3>
                            <div class="homework-meta">
                                <span><i class="fas fa-book"></i> <%= hw.subject ? hw.subject.name : 'N/A' %></span>
                                <span><i class="fas fa-calendar"></i> Due: <%= new Date(hw.dueDate).toLocaleDateString() %></span>
                                <span><i class="fas fa-clock"></i> <%= hw.countdownText %></span>
                            </div>
                        </div>
                        <div class="homework-actions">
                            <span class="status-badge <%= hw.status %>"><%= hw.statusText %></span>
                            <a href="/student/homework/<%= hw._id %>" class="btn btn-primary">
                                <%= hw.status === 'submitted' || hw.status === 'late' ? 'View' : 'Submit' %>
                            </a>
                        </div>
                    </div>
                    <% }); %>
                <% } else { %>
                <div class="empty-state">
                    <i class="fas fa-tasks"></i>
                    <h3>No homework found</h3>
                    <p>You're all caught up!</p>
                </div>
                <% } %>
            </div>
        </section>

        <!-- Quick Access -->
        <section class="section">
            <h2 class="section-title">Quick Access</h2>
            <div class="quick-access-grid">
                <a href="/student/subject" class="quick-btn">
                    <i class="fas fa-play-circle"></i>
                    <span>Start Quiz</span>
                </a>
                <a href="/student/performance" class="quick-btn">
                    <i class="fas fa-chart-line"></i>
                    <span>Performance</span>
                </a>
                <a href="/student/notifications" class="quick-btn">
                    <i class="fas fa-bell"></i>
                    <span>Notifications</span>
                </a>
                <a href="/student" class="quick-btn">
                    <i class="fas fa-tachometer-alt"></i>
                    <span>Dashboard</span>
                </a>
            </div>
        </section>
    </div>

    <style>
        .homework-page-container {
            min-height: 100vh;
            padding: var(--spacing-8);
            max-width: 1000px;
            margin: 0 auto;
        }

        .homework-list {
            display: flex;
            flex-direction: column;
            gap: var(--spacing-4);
        }

        .homework-item {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-xl);
            padding: var(--spacing-6);
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all var(--transition-normal);
        }

        .homework-item:hover {
            background: var(--glass-bg-hover);
            transform: translateX(4px);
        }

        .homework-info h3 {
            font-size: var(--font-size-lg);
            font-weight: 600;
            color: var(--white);
            margin-bottom: var(--spacing-2);
        }

        .homework-meta {
            display: flex;
            gap: var(--spacing-4);
            flex-wrap: wrap;
        }

        .homework-meta span {
            font-size: var(--font-size-sm);
            color: var(--gray-400);
        }

        .homework-meta i {
            color: var(--primary);
            margin-right: var(--spacing-1);
        }

        .homework-actions {
            display: flex;
            align-items: center;
            gap: var(--spacing-4);
        }

        @media (max-width: 768px) {
            .homework-page-container {
                padding: var(--spacing-4);
            }

            .homework-item {
                flex-direction: column;
                align-items: flex-start;
                gap: var(--spacing-4);
            }

            .homework-actions {
                width: 100%;
                justify-content: space-between;
            }
        }
    </style>
</body>
</html>
