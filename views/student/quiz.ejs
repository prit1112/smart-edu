<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz - <%= chapter.title %> - SmartEdu</title>
    <link rel="stylesheet" href="/css/unified.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        /* Quiz-specific overrides */
        .quiz-container {
            display: flex;
            min-height: 100vh;
        }

        .quiz-sidebar {
            width: 280px;
            background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);
            border-right: 1px solid var(--glass-border);
            position: fixed;
            height: 100vh;
            z-index: 100;
            display: flex;
            flex-direction: column;
        }

        .quiz-main {
            flex: 1;
            margin-left: 280px;
            padding: var(--spacing-8);
            max-width: 900px;
        }

        .quiz-header {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-2xl);
            padding: var(--spacing-6);
            margin-bottom: var(--spacing-6);
        }

        .quiz-title h1 {
            font-size: var(--font-size-2xl);
            font-weight: 700;
            color: var(--white);
            margin-bottom: var(--spacing-2);
            background: linear-gradient(135deg, var(--white), var(--primary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .quiz-meta {
            display: flex;
            gap: var(--spacing-4);
            flex-wrap: wrap;
            margin-bottom: var(--spacing-4);
        }

        .quiz-meta-item {
            display: flex;
            align-items: center;
            gap: var(--spacing-2);
            background: var(--glass-bg-hover);
            padding: var(--spacing-2) var(--spacing-4);
            border-radius: var(--radius-full);
            font-size: var(--font-size-sm);
            color: var(--gray-300);
        }

        .quiz-meta-item i {
            color: var(--primary);
        }

        .progress-text {
            display: flex;
            justify-content: space-between;
            font-size: var(--font-size-sm);
            color: var(--gray-400);
            margin-top: var(--spacing-2);
        }

        .timer {
            display: inline-flex;
            align-items: center;
            gap: var(--spacing-2);
            background: linear-gradient(135deg, var(--warning), #d97706);
            color: var(--white);
            padding: var(--spacing-3) var(--spacing-6);
            border-radius: var(--radius-xl);
            font-weight: 700;
            font-size: var(--font-size-lg);
        }

        .question-card {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-2xl);
            padding: var(--spacing-6);
            margin-bottom: var(--spacing-6);
            transition: all var(--transition-normal);
        }

        .question-card:hover {
            background: var(--glass-bg-hover);
            border-color: var(--glass-border-hover);
        }

        .question-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: var(--spacing-4);
        }

        .question-number {
            font-size: var(--font-size-sm);
            color: var(--gray-400);
            font-weight: 500;
        }

        .question-marks {
            background: rgba(245, 158, 11, 0.2);
            color: var(--warning);
            padding: var(--spacing-1) var(--spacing-3);
            border-radius: var(--radius-full);
            font-size: var(--font-size-xs);
            font-weight: 600;
        }

        .question-text {
            font-size: var(--font-size-lg);
            color: var(--white);
            margin-bottom: var(--spacing-6);
            line-height: 1.6;
            font-weight: 500;
        }

        .options {
            display: flex;
            flex-direction: column;
            gap: var(--spacing-3);
        }

        .option {
            display: flex;
            align-items: center;
            gap: var(--spacing-3);
            padding: var(--spacing-4);
            background: var(--glass-bg);
            border: 2px solid var(--glass-border);
            border-radius: var(--radius-xl);
            cursor: pointer;
            transition: all var(--transition-normal);
        }

        .option:hover {
            border-color: var(--primary);
            background: var(--glass-bg-hover);
            transform: translateX(4px);
        }

        .option.selected {
            border-color: var(--success);
            background: rgba(16, 185, 129, 0.1);
        }

        .option input[type="radio"] {
            width: 20px;
            height: 20px;
            accent-color: var(--success);
            cursor: pointer;
        }

        .option-text {
            color: var(--gray-200);
            flex: 1;
            font-size: var(--font-size-base);
        }

        .quiz-actions {
            display: flex;
            gap: var(--spacing-4);
            justify-content: center;
            margin-top: var(--spacing-8);
            flex-wrap: wrap;
        }

        /* Navigation buttons */
        .nav-btn {
            position: fixed;
            top: 50%;
            transform: translateY(-50%);
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-full);
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all var(--transition-normal);
            z-index: 100;
            color: var(--white);
        }

        .nav-btn:hover {
            background: var(--primary);
            border-color: var(--primary);
            transform: translateY(-50%) scale(1.1);
        }

        .nav-btn.prev {
            left: 290px;
        }

        .nav-btn.next {
            right: 20px;
        }

        @media (max-width: 1024px) {
            .quiz-sidebar {
                width: 80px;
            }
            
            .quiz-main {
                margin-left: 80px;
            }
            
            .nav-btn.prev {
                left: 90px;
            }
        }

        @media (max-width: 768px) {
            .quiz-container {
                flex-direction: column;
            }

            .quiz-sidebar {
                width: 100%;
                height: auto;
                position: sticky;
                top: 0;
                z-index: 100;
            }

            .question-nav {
                grid-template-columns: repeat(auto-fit, minmax(40px, 1fr));
            }

            .quiz-main {
                margin-left: 0;
                padding: var(--spacing-4);
            }

            .nav-btn {
                display: none;
            }

            .quiz-title h1 {
                font-size: var(--font-size-xl);
            }
        }
    </style>
</head>
<body>
    <!-- Bubble Effects -->
    <div class="bubbles">
        <div class="bubble bubble-1"></div>
        <div class="bubble bubble-2"></div>
        <div class="bubble bubble-3"></div>
        <div class="bubble bubble-4"></div>
        <div class="bubble bubble-5"></div>
        <div class="bubble bubble-6"></div>
        <div class="bubble bubble-7"></div>
        <div class="bubble bubble-8"></div>
        <div class="bubble bubble-9"></div>
        <div class="bubble bubble-10"></div>
    </div>

    <div class="quiz-container">
        <!-- Sidebar with Question Navigation -->
        <div class="quiz-sidebar">
            <div class="quiz-sidebar-header">
                <h2><i class="fas fa-list-ol"></i> Questions</h2>
            </div>
            <div class="question-nav">
                <% for (let i = 1; i <= questions.length; i++) { %>
                    <div class="question-nav-item" data-question="<%= i %>"><%= i %></div>
                <% } %>
            </div>
        </div>

        <!-- Main Quiz Content -->
        <div class="quiz-main">
            <div class="quiz-header">
                <div class="quiz-title">
                    <h1><%= chapter.title %></h1>
                </div>
                <div class="quiz-meta">
                    <div class="quiz-meta-item">
                        <i class="fas fa-book"></i>
                        <%= chapter.subject.name %>
                    </div>
                    <div class="quiz-meta-item">
                        <i class="fas fa-question-circle"></i>
                        <%= questions.length %> Questions
                    </div>
                    <div class="quiz-meta-item">
                        <i class="fas fa-clock"></i>
                        <span id="timer">30:00</span>
                    </div>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" id="progressFill" style="width: 0%;"></div>
                </div>
                <div class="progress-text">
                    <span id="progressText">0 of <%= questions.length %> answered</span>
                </div>
            </div>

            <form action="/student/quiz/<%= chapter._id %>" method="POST" id="quizForm">
                <% questions.forEach((question, index) => { %>
                    <div class="question-card" id="question-<%= index + 1 %>">
                        <div class="question-header">
                            <div class="question-number">Question <%= index + 1 %> of <%= questions.length %></div>
                            <div class="question-marks"><%= question.marks %> mark<%= question.marks > 1 ? 's' : '' %></div>
                        </div>
                        <div class="question-text"><%= question.question %></div>
                        <div class="options">
                            <% question.options.forEach((option, optionIndex) => { %>
                                <label class="option">
                                    <input type="radio" name="q_<%= question._id %>" value="<%= optionIndex %>">
                                    <span class="option-text"><%= option %></span>
                                </label>
                            <% }); %>
                        </div>
                    </div>
                <% }); %>

                <div class="quiz-actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-paper-plane"></i> Submit Quiz
                    </button>
                    <a href="/student/subject/<%= chapter.subject._id %>" class="btn btn-outline">
                        <i class="fas fa-arrow-left"></i> Back to Subject
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Navigation Buttons -->
    <button class="nav-btn prev" id="prevBtn">
        <i class="fas fa-chevron-left"></i>
    </button>
    <button class="nav-btn next" id="nextBtn">
        <i class="fas fa-chevron-right"></i>
    </button>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const questions = document.querySelectorAll('.question-card');
            const navItems = document.querySelectorAll('.question-nav-item');
            const options = document.querySelectorAll('.option input[type="radio"]');
            const progressFill = document.getElementById('progressFill');
            const progressText = document.getElementById('progressText');
            const timerElement = document.getElementById('timer');
            const quizForm = document.getElementById('quizForm');
            const prevBtn = document.getElementById('prevBtn');
            const nextBtn = document.getElementById('nextBtn');

            let currentQuestion = 1;
            let timeLeft = 30 * 60; // 30 minutes in seconds
            let timerInterval;

            // Start timer
            function startTimer() {
                timerInterval = setInterval(() => {
                    timeLeft--;
                    const minutes = Math.floor(timeLeft / 60);
                    const seconds = timeLeft % 60;
                    timerElement.textContent = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;

                    // Warning when low time
                    if (timeLeft <= 300) {
                        timerElement.parentElement.style.background = 'linear-gradient(135deg, #ef4444, #dc2626)';
                    }

                    if (timeLeft <= 0) {
                        clearInterval(timerInterval);
                        alert('Time is up! Submitting quiz...');
                        quizForm.submit();
                    }
                }, 1000);
            }

            // Update progress
            function updateProgress() {
                const answered = document.querySelectorAll('.option input[type="radio"]:checked').length;
                const percentage = (answered / questions.length) * 100;
                progressFill.style.width = `${percentage}%`;
                progressText.textContent = `${answered} of ${questions.length} answered`;
            }

            // Update navigation
            function updateNavigation() {
                navItems.forEach((item, index) => {
                    const questionNum = index + 1;
                    const questionCard = document.getElementById(`question-${questionNum}`);
                    const isAnswered = questionCard.querySelector('input[type="radio"]:checked');

                    item.classList.remove('answered', 'current');
                    if (isAnswered) {
                        item.classList.add('answered');
                    }
                    if (questionNum === currentQuestion) {
                        item.classList.add('current');
                    }
                });
            }

            // Navigate to question
            function navigateToQuestion(questionNum) {
                currentQuestion = questionNum;
                const targetQuestion = document.getElementById(`question-${questionNum}`);
                targetQuestion.scrollIntoView({ behavior: 'smooth', block: 'start' });
                updateNavigation();
            }

            // Option change handler
            options.forEach(option => {
                option.addEventListener('change', function() {
                    // Visual feedback
                    const parent = this.closest('.option');
                    parent.classList.add('selected');
                    
                    // Update progress and navigation
                    updateProgress();
                    updateNavigation();
                });
            });

            // Question nav click handler
            navItems.forEach(item => {
                item.addEventListener('click', () => {
                    const questionNum = parseInt(item.dataset.question);
                    navigateToQuestion(questionNum);
                });
            });

            // Previous button
            prevBtn.addEventListener('click', () => {
                if (currentQuestion > 1) {
                    navigateToQuestion(currentQuestion - 1);
                }
            });

            // Next button
            nextBtn.addEventListener('click', () => {
                if (currentQuestion < questions.length) {
                    navigateToQuestion(currentQuestion + 1);
                }
            });

            // Form submit handler
            quizForm.addEventListener('submit', function(e) {
                const unanswered = questions.length - document.querySelectorAll('.option input[type="radio"]:checked').length;
                if (unanswered > 0) {
                    const confirmSubmit = confirm(`You have ${unanswered} unanswered question${unanswered > 1 ? 's' : ''}. Are you sure you want to submit?`);
                    if (!confirmSubmit) {
                        e.preventDefault();
                    }
                }
            });

            // Initialize
            startTimer();
            updateProgress();
            updateNavigation();
        });
    </script>
</body>
</html>
