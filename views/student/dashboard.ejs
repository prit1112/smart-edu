<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard - SmartEdu</title>
    <link rel="stylesheet" href="/css/unified.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <!-- Bubble Effects -->
    <div class="bubbles">
        <div class="bubble bubble-1"></div>
        <div class="bubble bubble-2"></div>
        <div class="bubble bubble-3"></div>
        <div class="bubble bubble-4"></div>
        <div class="bubble bubble-5"></div>
        <div class="bubble bubble-6"></div>
        <div class="bubble bubble-7"></div>
        <div class="bubble bubble-8"></div>
        <div class="bubble bubble-9"></div>
        <div class="bubble bubble-10"></div>
    </div>

    <div class="dashboard-container">
        <!-- Sidebar -->
        <nav class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="logo">
                    <i class="fas fa-graduation-cap"></i>
                    <span>SmartEdu</span>
                </div>
                <button class="toggle-btn" id="toggle-btn">
                    <i class="fas fa-bars"></i>
                </button>
            </div>
            <ul class="sidebar-menu">
                <li><a href="/student" class="active"><i class="fas fa-tachometer-alt icon"></i><span>Dashboard</span></a></li>
                <li><a href="/student/performance"><i class="fas fa-chart-line icon"></i><span>Performance</span></a></li>
                <li><a href="/student/subject"><i class="fas fa-book icon"></i><span>Subjects</span></a></li>
                <li><a href="/student/homework"><i class="fas fa-tasks icon"></i><span>Homework</span></a></li>
                <li><a href="/student/history"><i class="fas fa-history icon"></i><span>History</span></a></li>
                <li><a href="/student/notifications"><i class="fas fa-bell icon"></i><span>Notifications</span></a></li>
            </ul>
        </nav>

        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <!-- Header -->
            <header class="header">
                <div class="student-info">
                    <img src="<%= user.avatar || '/images/default-avatar.png' %>" alt="Avatar" class="avatar">
                    <div>
                        <h3>Welcome back, <%= user.name %>!</h3>
                        <p>Class <%= user.classLevel %></p>
                    </div>
                </div>
                <div class="header-right">
                    <div class="search-bar">
                        <input type="text" placeholder="Search..." id="dashboardSearch">
                        <button><i class="fas fa-search"></i></button>
                    </div>
                    <button class="notification-btn" id="notificationTrigger">
                        <i class="fas fa-bell"></i>
                        <span class="notification-badge" id="notificationBadge" style="display: none;">0</span>
                    </button>
                </div>
            </header>

            <!-- Content -->
            <main class="content">
                <!-- Welcome Hero -->
                <section class="welcome-hero">
                    <div class="welcome-content">
                        <h1>Good <%= new Date().getHours() < 12 ? 'Morning' : new Date().getHours() < 18 ? 'Afternoon' : 'Evening' %>, <%= user.name %>!</h1>
                        <p>Ready to continue your learning journey? Let's make today productive!</p>
                        <div class="welcome-meta">
                            <div class="welcome-meta-item">
                                <i class="fas fa-calendar-check"></i>
                                <span><%= new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                            </div>
                            <div class="welcome-meta-item">
                                <i class="fas fa-clock"></i>
                                <span>Last updated: Just now</span>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Stats Overview -->
                <section class="section">
                    <h2 class="section-title">Dashboard Overview</h2>
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-bell"></i>
                            </div>
                            <div class="stat-data">
                                <h3 id="dashboardUnreadNotifications">0</h3>
                                <p>Unread Notifications</p>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-book"></i>
                            </div>
                            <div class="stat-data">
                                <h3><%= courses ? courses.length : 0 %></h3>
                                <p>Active Subjects</p>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-calendar-check"></i>
                            </div>
                            <div class="stat-data">
                                <h3><%= attendance && typeof attendance.percentage !== 'undefined' ? attendance.percentage : 0 %>%</h3>
                                <p>Attendance Rate</p>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-graduation-cap"></i>
                            </div>
                            <div class="stat-data">
                                <h3><%= typeof gpa !== 'undefined' ? gpa : 0 %></h3>
                                <p>Current GPA</p>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-tasks"></i>
                            </div>
                            <div class="stat-data">
                                <h3><%= assignments ? assignments.filter(a => a.status === 'pending').length : 0 %></h3>
                                <p>Pending Assignments</p>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Quick Access -->
                <section class="section">
                    <h2 class="section-title">Quick Access</h2>
                    <div class="quick-access-grid">
                        <a href="/student/subject" class="quick-btn">
                            <i class="fas fa-play-circle"></i>
                            <span>Start Learning</span>
                        </a>
                        <a href="/student/homework" class="quick-btn">
                            <i class="fas fa-tasks"></i>
                            <span>Homework</span>
                        </a>
                        <a href="/student/performance" class="quick-btn">
                            <i class="fas fa-chart-line"></i>
                            <span>Performance</span>
                        </a>
                        <a href="/student/notifications" class="quick-btn">
                            <i class="fas fa-bell"></i>
                            <span>Notifications</span>
                        </a>
                    </div>
                </section>

                <!-- Recent Assignments -->
                <section class="section">
                    <h2 class="section-title">Recent Assignments</h2>
                    <div class="assignments-list">
                        <% if (assignments && assignments.length > 0) { %>
                            <% assignments.slice(0, 5).forEach(assignment => { %>
                            <div class="assignment-item">
                                <div class="assignment-info">
                                    <h4><%= assignment.title %></h4>
                                    <p>Due: <%= assignment.dueDate %></p>
                                </div>
                                <span class="status-badge <%= assignment.status %>"><%= assignment.status %></span>
                            </div>
                            <% }); %>
                        <% } else { %>
                        <div class="empty-state">
                            <i class="fas fa-clipboard-list"></i>
                            <h3>No assignments available</h3>
                            <p>Check back later for new assignments</p>
                        </div>
                        <% } %>
                    </div>
                </section>
            </main>
        </div>
    </div>

    <!-- Notification Dropdown -->
    <div class="notification-dropdown" id="notificationDropdown" style="display: none;">
        <div class="dropdown-header">
            <h4>Recent Notifications</h4>
            <a href="/student/notifications">View All</a>
        </div>
        <div class="dropdown-content" id="notificationList">
            <!-- Notifications loaded here -->
        </div>
    </div>

    <script src="/js/dashboard.js"></script>
    <script>
        // Initialize dashboard
        document.addEventListener('DOMContentLoaded', function() {
            // Sidebar toggle
            const sidebar = document.getElementById('sidebar');
            const toggleBtn = document.getElementById('toggle-btn');
            
            if (toggleBtn && sidebar) {
                toggleBtn.addEventListener('click', function() {
                    sidebar.classList.toggle('open');
                });
            }

            // Notification dropdown
            const notificationBtn = document.getElementById('notificationTrigger');
            const dropdown = document.getElementById('notificationDropdown');

            if (notificationBtn && dropdown) {
                notificationBtn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
                });

                document.addEventListener('click', function(e) {
                    if (!notificationBtn.contains(e.target) && !dropdown.contains(e.target)) {
                        dropdown.style.display = 'none';
                    }
                });
            }

            // Fetch notification count
            fetchNotificationCount();
        });

        async function fetchNotificationCount() {
            try {
                const response = await fetch('/student/notifications/count');
                if (response.ok) {
                    const data = await response.json();
                    updateNotificationBadge(data.unread || 0);
                }
            } catch (error) {
                console.error('Error fetching notification count:', error);
            }
        }

        function updateNotificationBadge(count) {
            const badge = document.getElementById('notificationBadge');
            const dashboardCount = document.getElementById('dashboardUnreadNotifications');

            if (badge) {
                if (count > 0) {
                    badge.textContent = count > 99 ? '99+' : count;
                    badge.style.display = 'flex';
                } else {
                    badge.style.display = 'none';
                }
            }

            if (dashboardCount) {
                dashboardCount.textContent = count;
            }
        }
    </script>
</body>
</html>
