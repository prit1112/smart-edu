<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Video Lectures - SmartEdu</title>
    <link rel="stylesheet" href="/css/unified.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <div class="videos-page-container">
        <!-- Page Header -->
        <div class="page-header">
            <h1><i class="fas fa-video"></i> Video Lectures</h1>
            <p>Watch engaging video lectures for <%= chapter ? chapter.title : 'your subjects' %></p>
        </div>

        <!-- Videos List -->
        <section class="section">
            <h2 class="section-title">Available Videos</h2>
            <div class="videos-list">
                <% if (videos && videos.length > 0) { %>
                    <% videos.forEach(function(video) { %>
                    <div class="video-item">
                        <div class="video-icon">
                            <i class="fas fa-play-circle"></i>
                        </div>
                        <div class="video-info">
                            <h3><%= video.title %></h3>
                            <p><%= video.description || 'Video lecture for this chapter' %></p>
                        </div>
                        <div class="video-actions">
                            <a href="<%= video.url %>" target="_blank" class="btn btn-primary">
                                <i class="fas fa-play"></i> Watch
                            </a>
                        </div>
                    </div>
                    <% }); %>
                <% } else { %>
                <div class="empty-state">
                    <i class="fas fa-video-slash"></i>
                    <h3>No Videos Available</h3>
                    <p>Video lectures will be uploaded soon.</p>
                </div>
                <% } %>
            </div>
        </section>

        <!-- Quick Access -->
        <section class="section">
            <h2 class="section-title">Quick Access</h2>
            <div class="quick-access-grid">
                <a href="/student/subject/<%= chapter ? chapter.subject : '' %>" class="quick-btn">
                    <i class="fas fa-arrow-left"></i>
                    <span>Back to Subject</span>
                </a>
                <a href="/student/notes/<%= chapter ? chapter._id : '' %>" class="quick-btn">
                    <i class="fas fa-file-alt"></i>
                    <span>View Notes</span>
                </a>
                <a href="/student/quiz/<%= chapter ? chapter._id : '' %>" class="quick-btn">
                    <i class="fas fa-play-circle"></i>
                    <span>Take Quiz</span>
                </a>
                <a href="/student/performance" class="quick-btn">
                    <i class="fas fa-chart-line"></i>
                    <span>Performance</span>
                </a>
            </div>
        </section>
    </div>

    <style>
        .videos-page-container {
            min-height: 100vh;
            padding: var(--spacing-8);
            max-width: 1000px;
            margin: 0 auto;
        }

        .videos-list {
            display: flex;
            flex-direction: column;
            gap: var(--spacing-4);
        }

        .video-item {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-xl);
            padding: var(--spacing-6);
            display: flex;
            align-items: center;
            gap: var(--spacing-4);
            transition: all var(--transition-normal);
        }

        .video-item:hover {
            background: var(--glass-bg-hover);
            transform: translateX(4px);
        }

        .video-icon {
            font-size: 2.5rem;
            color: var(--primary);
            flex-shrink: 0;
        }

        .video-info {
            flex: 1;
        }

        .video-info h3 {
            font-size: var(--font-size-lg);
            font-weight: 600;
            color: var(--white);
            margin-bottom: var(--spacing-2);
        }

        .video-info p {
            font-size: var(--font-size-sm);
            color: var(--gray-400);
            margin: 0;
        }

        @media (max-width: 768px) {
            .videos-page-container {
                padding: var(--spacing-4);
            }

            .video-item {
                flex-direction: column;
                text-align: center;
            }

            .video-actions {
                width: 100%;
            }

            .video-actions .btn {
                width: 100%;
            }
        }
    </style>
</body>
</html>
