<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= subject.name %> - SmartEdu</title>
    <link rel="stylesheet" href="/css/unified.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <div class="subject-page-container">
        <!-- Page Header -->
        <div class="page-header">
            <h1><i class="fas fa-book-open"></i> <%= subject.name %></h1>
            <p>Explore chapters, take quizzes, and master your subject</p>
        </div>

        <!-- Stats Overview -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-list"></i></div>
                <div class="stat-data">
                    <h3><%= chapters.length %></h3>
                    <p>Total Chapters</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-question-circle"></i></div>
                <div class="stat-data">
                    <h3><%= chapters.filter(function(c) { return c.quizAvailable; }).length %></h3>
                    <p>Available Quizzes</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-chart-line"></i></div>
                <div class="stat-data">
                    <h3><%= Math.round(chapters.reduce(function(sum, c) { return sum + c.progress; }, 0) / chapters.length) %>%</h3>
                    <p>Average Progress</p>
                </div>
            </div>
        </div>

        <!-- Chapters List -->
        <section class="section">
            <h2 class="section-title">Course Chapters</h2>
            <div class="chapters-list">
                <% if (chapters && chapters.length > 0) { %>
                    <% chapters.forEach(function(chapter) { %>
                    <div class="chapter-item">
                        <div class="chapter-info">
                            <h3><%= chapter.title %></h3>
                            <div class="chapter-meta">
                                <span><i class="fas fa-question-circle"></i> <%= chapter.mcqCount %> Questions</span>
                                <span><i class="fas fa-chart-line"></i> <%= chapter.progress %>% Progress</span>
                            </div>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: <%= chapter.progress %>%"></div>
                            </div>
                        </div>
                        <div class="chapter-actions">
                            <span class="status-badge <%= chapter.quizAvailable ? 'completed' : chapter.hasAttempted ? 'completed' : 'pending' %>">
                                <%= chapter.quizAvailable ? 'Quiz Ready' : chapter.hasAttempted ? 'Completed' : 'Not Started' %>
                            </span>
                            <% if (chapter.quizAvailable || chapter.hasAttempted) { %>
                                <% if (chapter.hasAttempted) { %>
                                    <a href="/student/result/<%= chapter.resultId %>" class="btn btn-primary">
                                        <i class="fas fa-eye"></i> View Result
                                    </a>
                                <% } else { %>
                                    <a href="/student/quiz/<%= chapter._id %>" class="btn btn-primary">
                                        <i class="fas fa-play"></i> Start Quiz
                                    </a>
                                <% } %>
                            <% } %>
                            <a href="/student/notes/<%= chapter._id %>" class="btn btn-ghost">
                                <i class="fas fa-file-alt"></i> Notes
                            </a>
                            <a href="/student/videos/<%= chapter._id %>" class="btn btn-ghost">
                                <i class="fas fa-video"></i> Videos
                            </a>
                        </div>
                    </div>
                    <% }); %>
                <% } else { %>
                <div class="empty-state">
                    <i class="fas fa-book"></i>
                    <h3>No chapters available</h3>
                    <p>Check back later for new content.</p>
                </div>
                <% } %>
            </div>
        </section>

        <!-- Quick Access -->
        <section class="section">
            <h2 class="section-title">Quick access</h2>
            <div class="quick-access-grid">
                <a href="/student/subjects" class="quick-btn">
                    <i class="fas fa-arrow-left"></i>
                    <span>All Subjects</span>
                </a>
                <a href="/student/performance" class="quick-btn">
                    <i class="fas fa-chart-line"></i>
                    <span>Performance</span>
                </a>
                <a href="/student/homework" class="quick-btn">
                    <i class="fas fa-tasks"></i>
                    <span>Homework</span>
                </a>
                <a href="/student/notifications" class="quick-btn">
                    <i class="fas fa-bell"></i>
                    <span>Notifications</span>
                </a>
            </div>
        </section>
    </div>

    <style>
        .subject-page-container {
            min-height: 100vh;
            padding: var(--spacing-8);
            max-width: 1000px;
            margin: 0 auto;
        }

        .chapters-list {
            display: flex;
            flex-direction: column;
            gap: var(--spacing-4);
        }

        .chapter-item {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-xl);
            padding: var(--spacing-6);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: var(--spacing-4);
            transition: all var(--transition-normal);
        }

        .chapter-item:hover {
            background: var(--glass-bg-hover);
            transform: translateX(4px);
        }

        .chapter-info {
            flex: 1;
        }

        .chapter-info h3 {
            font-size: var(--font-size-lg);
            font-weight: 600;
            color: var(--white);
            margin-bottom: var(--spacing-2);
        }

        .chapter-meta {
            display: flex;
            gap: var(--spacing-4);
            margin-bottom: var(--spacing-3);
        }

        .chapter-meta span {
            font-size: var(--font-size-sm);
            color: var(--gray-400);
        }

        .chapter-meta i {
            color: var(--primary);
            margin-right: var(--spacing-1);
        }

        .chapter-actions {
            display: flex;
            align-items: center;
            gap: var(--spacing-3);
            flex-shrink: 0;
        }

        @media (max-width: 768px) {
            .subject-page-container {
                padding: var(--spacing-4);
            }

            .chapter-item {
                flex-direction: column;
                align-items: flex-start;
            }

            .chapter-actions {
                width: 100%;
                flex-wrap: wrap;
            }

            .chapter-actions .btn {
                flex: 1;
                min-width: 120px;
            }
        }
    </style>
</body>
</html>
