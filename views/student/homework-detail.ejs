<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - SmartEdu</title>
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="dashboard">
        <!-- Sidebar -->
        <nav class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="logo">
                    <i class="fas fa-graduation-cap"></i>
                    SmartEdu
                </div>
                <button class="toggle-btn" id="toggle-btn">
                    <i class="fas fa-bars"></i>
                </button>
            </div>
            <ul class="sidebar-menu">
                <li><a href="/student"><i class="fas fa-tachometer-alt icon"></i><span>Dashboard</span></a></li>
                <li><a href="/student/performance"><i class="fas fa-chart-line icon"></i><span>Performance</span></a></li>
                <li><a href="/student/subject"><i class="fas fa-book icon"></i><span>Subjects</span></a></li>
                <li><a href="/student/homework" class="active"><i class="fas fa-tasks icon"></i><span>Homework</span></a></li>
                <li><a href="/student/history"><i class="fas fa-history icon"></i><span>History</span></a></li>
                <li><a href="/student/notifications"><i class="fas fa-bell icon"></i><span>Notifications</span></a></li>
            </ul>
        </nav>

        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <!-- Header -->
            <header class="header">
                <div class="header-left">
                    <div class="student-info">
                        <img src="<%= user.avatar || '/images/default-avatar.png' %>" alt="Avatar" class="avatar">
                        <div>
                            <h3>Welcome back, <%= user.name %>!</h3>
                            <p>Class <%= user.classLevel %></p>
                        </div>
                    </div>
                </div>
                <div class="header-right">
                    <div class="search-bar">
                        <input type="text" placeholder="Search homework details...">
                        <button><i class="fas fa-search"></i></button>
                    </div>
                    <button class="notification-btn">
                        <i class="fas fa-bell"></i>
                    </button>
                </div>
            </header>

            <!-- Content -->
            <main class="content">
                <!-- Enhanced Hero Section -->
                <section class="performance-hero">
                    <div class="hero-background">
                        <div class="gradient-orb orb-1"></div>
                        <div class="gradient-orb orb-2"></div>
                        <div class="gradient-orb orb-3"></div>
                        <div class="floating-elements">
                            <div class="float-element elem-1"><i class="fas fa-book"></i></div>
                            <div class="float-element elem-2"><i class="fas fa-star"></i></div>
                            <div class="float-element elem-3"><i class="fas fa-graduation-cap"></i></div>
                            <div class="float-element elem-4"><i class="fas fa-tasks"></i></div>
                        </div>
                    </div>
                    <div class="hero-content">
                        <div class="hero-icon-wrapper">
                            <div class="hero-icon-glow"></div>
                            <i class="hero-icon fas fa-book-open"></i>
                            <div class="icon-particles">
                                <span></span><span></span><span></span><span></span><span></span>
                            </div>
                        </div>
                        <div class="hero-title">
                            <h1 class="title-gradient"><%= homework.title %></h1>
                            <div class="title-underline"></div>
                        </div>
                        <p class="hero-subtitle">Complete your homework assignment and track your progress</p>
                        <div class="hero-metrics">
                            <div class="metric">
                                <span class="metric-value"><%= homework.maxMarks %></span>
                                <span class="metric-label">Max Marks</span>
                            </div>
                            <div class="metric">
                                <span class="metric-value"><%= statusText %></span>
                                <span class="metric-label">Status</span>
                            </div>
                            <div class="metric">
                                <span class="metric-value"><%= homework.subject.name %></span>
                                <span class="metric-label">Subject</span>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Enhanced Summary Cards -->
                <section class="summary-section">
                    <div class="summary-grid">
                        <div class="summary-card">
                            <div class="card-glow"></div>
                            <div class="card-content">
                                <i class="card-icon fas fa-graduation-cap"></i>
                                <div class="card-data">
                                    <div class="card-label">Subject</div>
                                    <div class="counter"><%= homework.subject.name %></div>
                                </div>
                            </div>
                        </div>
                        <div class="summary-card">
                            <div class="card-glow"></div>
                            <div class="card-content">
                                <i class="card-icon fas fa-calendar-alt"></i>
                                <div class="card-data">
                                    <div class="card-label">Due Date</div>
                                    <div class="counter"><%= new Date(homework.dueDate).toLocaleDateString() %></div>
                                </div>
                            </div>
                        </div>
                        <div class="summary-card">
                            <div class="card-glow"></div>
                            <div class="card-content">
                                <i class="card-icon fas fa-star"></i>
                                <div class="card-data">
                                    <div class="card-label">Max Marks</div>
                                    <div class="counter"><%= homework.maxMarks %></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Enhanced Homework Details -->
                <section class="charts-section">
                    <div class="chart-container">
                        <h3>Homework Description</h3>
                        <div class="description-content" style="background: rgba(30, 30, 30, 0.8); padding: 20px; border-radius: 10px; border: 1px solid rgba(255, 255, 255, 0.1);">
                            <%= homework.description.replace(/\n/g, '<br>') %>
                        </div>
                        <% if (homework.attachments && homework.attachments.length > 0) { %>
                        <h3 style="margin-top: 30px;">Attachments</h3>
                        <div class="attachments-list" style="display: flex; flex-direction: column; gap: 10px;">
                            <% homework.attachments.forEach(file => { %>
                            <a href="/uploads/homework/<%= file %>" target="_blank" class="attachment-link" style="display: inline-flex; align-items: center; gap: 10px; padding: 12px 16px; background: rgba(0, 212, 255, 0.1); border: 1px solid rgba(0, 212, 255, 0.2); border-radius: 8px; text-decoration: none; color: #00d4ff; transition: all 0.3s ease;">
                                <i class="fas fa-file"></i> <%= file %>
                            </a>
                            <% }); %>
                        </div>
                        <% } %>
                    </div>

                    <% if (submission && submission.marksObtained !== undefined) { %>
                    <div class="chart-container">
                        <h3>Your Performance</h3>
                        <div class="circular-progress" style="margin: 0 auto;">
                            <svg width="150" height="150">
                                <circle cx="75" cy="75" r="60" stroke="#333" stroke-width="10" fill="none"></circle>
                                <circle cx="75" cy="75" r="60" stroke="#00d4ff" stroke-width="10" fill="none" stroke-dasharray="376.99" stroke-dashoffset="<%= 376.99 - (submission.marksObtained / homework.maxMarks) * 376.99 %>"></circle>
                            </svg>
                            <div class="gpa-text">
                                <div class="gpa-number"><%= submission.marksObtained %></div>
                                <div class="gpa-label">/<%= homework.maxMarks %></div>
                            </div>
                        </div>
                        <div style="text-align: center; margin-top: 20px;">
                            <div class="trend-indicator <%= submission.marksObtained >= homework.maxMarks * 0.8 ? 'up' : submission.marksObtained >= homework.maxMarks * 0.6 ? 'warning' : 'down' %>">
                                <i class="fas fa-<%= submission.marksObtained >= homework.maxMarks * 0.8 ? 'trophy' : submission.marksObtained >= homework.maxMarks * 0.6 ? 'star-half-alt' : 'exclamation-triangle' %>"></i>
                                <%= submission.marksObtained >= homework.maxMarks * 0.8 ? 'Excellent' : submission.marksObtained >= homework.maxMarks * 0.6 ? 'Good' : 'Needs Improvement' %>
                            </div>
                        </div>
                    </div>
                    <% } %>
                </section>

                <!-- Enhanced Submission Section -->
                <section class="assignments-section">
                    <h2>Your Submission</h2>
                    <% if (submission) { %>
                    <div class="assignment-item" style="background: linear-gradient(135deg, rgba(30, 30, 30, 0.9) 0%, rgba(25, 25, 25, 0.9) 100%); backdrop-filter: blur(25px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 20px; padding: 30px; position: relative; overflow: hidden;">
                        <div class="card-glow"></div>
                        <div class="assignment-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                            <h4 style="color: #e0e0e0; margin: 0; font-size: 1.5rem;">Submission Details</h4>
                            <span class="status <%= status %>" style="padding: 8px 16px; border-radius: 20px; font-weight: 600; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.5px;"><%= statusText %></span>
                        </div>
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">
                            <div style="background: rgba(255, 255, 255, 0.05); padding: 15px; border-radius: 10px;">
                                <strong style="color: #00d4ff;">Submitted:</strong>
                                <p style="color: #e0e0e0; margin: 5px 0 0 0;"><%= new Date(submission.submittedAt).toLocaleString() %></p>
                            </div>
                            <% if (submission.marksObtained !== undefined) { %>
                            <div style="background: rgba(255, 255, 255, 0.05); padding: 15px; border-radius: 10px;">
                                <strong style="color: #00d4ff;">Marks:</strong>
                                <p style="color: #e0e0e0; margin: 5px 0 0 0; font-size: 1.2rem; font-weight: bold;"><%= submission.marksObtained %>/<%= homework.maxMarks %></p>
                            </div>
                            <% } %>
                            <% if (submission.feedback) { %>
                            <div style="background: rgba(255, 255, 255, 0.05); padding: 15px; border-radius: 10px; grid-column: 1 / -1;">
                                <strong style="color: #00d4ff;">Feedback:</strong>
                                <p style="color: #e0e0e0; margin: 5px 0 0 0;"><%= submission.feedback %></p>
                            </div>
                            <% } %>
                        </div>
                        <% if (submission.file) { %>
                        <div style="margin-top: 20px; padding-top: 20px; border-top: 1px solid rgba(255, 255, 255, 0.1);">
                            <h4 style="color: #e0e0e0; margin-bottom: 10px;">Submitted File</h4>
                            <a href="/uploads/homework/<%= submission.file %>" target="_blank" style="display: inline-flex; align-items: center; gap: 10px; padding: 12px 16px; background: rgba(0, 212, 255, 0.1); border: 1px solid rgba(0, 212, 255, 0.2); border-radius: 8px; text-decoration: none; color: #00d4ff; transition: all 0.3s ease;">
                                <i class="fas fa-file"></i> <%= submission.file %>
                            </a>
                        </div>
                        <% } %>
                        <% if (submission.textAnswer) { %>
                        <div style="margin-top: 20px; padding-top: 20px; border-top: 1px solid rgba(255, 255, 255, 0.1);">
                            <h4 style="color: #e0e0e0; margin-bottom: 10px;">Text Answer</h4>
                            <div style="background: rgba(255, 255, 255, 0.05); padding: 15px; border-radius: 10px; border: 1px solid rgba(255, 255, 255, 0.1);">
                                <%= submission.textAnswer.replace(/\n/g, '<br>') %>
                            </div>
                        </div>
                        <% } %>
                    </div>
                    <% } else if (canSubmit) { %>
                    <div class="assignment-item" style="background: linear-gradient(135deg, rgba(30, 30, 30, 0.9) 0%, rgba(25, 25, 25, 0.9) 100%); backdrop-filter: blur(25px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 20px; padding: 30px; position: relative; overflow: hidden;">
                        <div class="card-glow"></div>
                        <h4 style="color: #e0e0e0; margin-bottom: 20px; font-size: 1.5rem;">Submit Your Homework</h4>
                        <form method="POST" action="/student/homework/<%= homework._id %>/submit" enctype="multipart/form-data">
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                                <div class="form-group" style="grid-column: 1 / -1;">
                                    <label for="textAnswer" style="display: block; margin-bottom: 8px; color: #e0e0e0; font-weight: 500;">Text Answer (Optional)</label>
                                    <textarea id="textAnswer" name="textAnswer" rows="6" placeholder="Write your answer here..." style="width: 100%; padding: 12px; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 8px; color: #e0e0e0; font-family: inherit; resize: vertical;"></textarea>
                                </div>
                                <div class="form-group">
                                    <label for="homeworkFile" style="display: block; margin-bottom: 8px; color: #e0e0e0; font-weight: 500;">Upload File (Optional)</label>
                                    <input type="file" id="homeworkFile" name="homeworkFile" accept=".pdf,.doc,.docx,.txt,.jpg,.jpeg,.png" style="width: 100%; padding: 12px; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 8px; color: #e0e0e0;">
                                    <small style="display: block; margin-top: 5px; color: #a0a0a0; font-size: 0.9rem;">Supported formats: PDF, DOC, DOCX, TXT, JPG, PNG (Max 20MB)</small>
                                </div>
                            </div>
                            <div style="text-align: center;">
                                <button type="submit" style="padding: 15px 30px; background: linear-gradient(45deg, #00d4ff, #8a2be2); border: none; border-radius: 25px; color: white; font-weight: 600; font-size: 1rem; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(0, 212, 255, 0.3);">
                                    <i class="fas fa-paper-plane" style="margin-right: 8px;"></i>Submit Homework
                                </button>
                            </div>
                        </form>
                    </div>
                    <% } else { %>
                    <div class="assignment-item" style="background: linear-gradient(135deg, rgba(30, 30, 30, 0.9) 0%, rgba(25, 25, 25, 0.9) 100%); backdrop-filter: blur(25px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 20px; padding: 30px; text-align: center;">
                        <i class="fas fa-check-circle" style="font-size: 3rem; color: #00d4ff; margin-bottom: 15px;"></i>
                        <p style="color: #e0e0e0; font-size: 1.2rem;">You have already submitted this homework.</p>
                    </div>
                    <% } %>
                </section>

                <!-- Enhanced Quick Access -->
                <section class="quick-access-section">
                    <h2>Quick Access</h2>
                    <div class="quick-access-buttons">
                        <a href="/student/homework" class="quick-btn">
                            <i class="fas fa-arrow-left"></i>
                            <span>Back to Homework</span>
                        </a>
                        <a href="/student/subject" class="quick-btn">
                            <i class="fas fa-play-circle"></i>
                            <span>Start Quiz</span>
                        </a>
                        <a href="/student/performance" class="quick-btn">
                            <i class="fas fa-chart-line"></i>
                            <span>Check Performance</span>
                        </a>
                        <a href="/student/notifications" class="quick-btn">
                            <i class="fas fa-bell"></i>
                            <span>Notifications</span>
                        </a>
                        <a href="/student" class="quick-btn">
                            <i class="fas fa-tachometer-alt"></i>
                            <span>Dashboard</span>
                        </a>
                    </div>
                </section>
            </main>
        </div>
    </div>

    <script src="/js/dashboard.js"></script>
</body>
</html>
